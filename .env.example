# ============================================================================
# DRD Digital - Environment Variables Template
# Copy this file to .env.local and fill in your actual values
# ============================================================================

# ----------------------------------------------------------------------------
# NOTION CMS CONFIGURATION
# ----------------------------------------------------------------------------
# Get your integration token from: https://www.notion.so/my-integrations
# Create a new integration, copy the "Internal Integration Token"
NOTION_TOKEN=ntn_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Database IDs from Notion (get from URL: notion.so/workspace/[DB_ID]?v=...)
# Case Studies Database
NOTION_CASE_STUDIES_DATABASE_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# Research Articles Database  
NOTION_RESEARCH_DATABASE_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# Partners Database
NOTION_PARTNERS_DATABASE_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# ----------------------------------------------------------------------------
# SUPABASE CONFIGURATION
# ----------------------------------------------------------------------------
# Get from: https://app.supabase.com/project/_/settings/api
# Project URL (find in Project Settings > API)
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co

# Anon Key (public, safe for browser)
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Service Role Key (SECRET - server only, never expose to browser)
# Used for admin operations like writing leads from API routes
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ----------------------------------------------------------------------------
# OPTIONAL: VERCEL / DEPLOYMENT
# ----------------------------------------------------------------------------
# For production deployments on Vercel, add these in:
# Project Settings > Environment Variables
# ----------------------------------------------------------------------------
