{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "axis-platform", // Ensure this matches your project name in Cloudflare
  "compatibility_date": "2026-03-15",
  "compatibility_flags": [
    "nodejs_compat"
  ],
  "assets": {
    "directory": "./dist",
    "binding": "ASSETS"
  },
  "observability": {
    "enabled": true
  }
}
