# ═══════════════════════════════════════════════════════════════════════════
# AXIS MEDIA — Environment Variables Template
# Copy to .env and fill all values before running locally or deploying.
# NEVER commit the filled .env file to version control.
# ═══════════════════════════════════════════════════════════════════════════

# ── App ────────────────────────────────────────────────────────────────────
DEBUG=false
SECRET_KEY=replace-with-a-64-char-random-string

# ── Supabase ────────────────────────────────────────────────────────────────
# Project URL from: Supabase Dashboard → Settings → API
SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co

# Service Role Key (server-side only — NEVER expose to frontend)
SUPABASE_SERVICE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Anon key for frontend (safe to expose)
PUBLIC_SUPABASE_ANON=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Storage bucket names
PDF_STORAGE_BUCKET=gap-reports

# ── Resend (Email) ────────────────────────────────────────────────────────
# https://resend.com/api-keys
RESEND_API_KEY=re_...
RESEND_FROM=AXIS Infrastructure <axis@axismediaws.com>

# ── Safaricom Daraja (M-Pesa) ─────────────────────────────────────────────
# https://developer.safaricom.co.ke → My Apps
DARAJA_CONSUMER_KEY=your_consumer_key
DARAJA_CONSUMER_SECRET=your_consumer_secret
DARAJA_SHORTCODE=174379              # Use 174379 for sandbox
DARAJA_PASSKEY=bfb279f9aa9bdbcf158e97dd71a467cd2e0c893059b10f78e6b72ada1ed2c919
DARAJA_CALLBACK_URL=https://axismediaws.com/api/v1/daraja/callback
DARAJA_ENV=sandbox                   # Change to 'production' for live

# ── Telegram ──────────────────────────────────────────────────────────────
# 1. Message @BotFather to create a bot
# 2. Get your chat_id from @userinfobot
TELEGRAM_BOT_TOKEN=7123456789:AAF...
TELEGRAM_CEO_CHAT_ID=123456789

# ── Redis (Celery Broker) ─────────────────────────────────────────────────
# Local: redis://localhost:6379/0
# Production: Use Upstash Redis (free tier available)
REDIS_URL=redis://localhost:6379/0

# ── Cloudflare ────────────────────────────────────────────────────────────
CF_API_TOKEN=your_cloudflare_api_token
CF_ACCOUNT_ID=your_account_id

# ── Render (Backend Deploy Hook) ──────────────────────────────────────────
RENDER_DEPLOY_HOOK=https://api.render.com/deploy/srv-...?key=...
