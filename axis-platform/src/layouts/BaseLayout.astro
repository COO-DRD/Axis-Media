---
import '../styles/global.css';
interface Props {
  title: string;
  description?: string;
  page?: string;
}
const { title, description = 'AXIS Media and Web Services — Digital systems for Kenyan businesses. Websites, M-Pesa payments, automation. Mombasa & Nairobi.', page = '' } = Astro.props;
const canonical = new URL(Astro.url.pathname, 'https://axismediaws.com');
---
<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width,initial-scale=1.0"/>
  <meta name="theme-color" content="#060E08"/>
  <title>{title} | AXIS Media & Web Services</title>
  <meta name="description" content={description}/>
  <link rel="canonical" href={canonical}/>
  <meta property="og:title" content={`${title} | AXIS Media`}/>
  <meta property="og:description" content={description}/>
  <meta property="og:type" content="website"/>
  <meta name="geo.region" content="KE-MSA"/>
  <meta name="geo.placename" content="Mombasa, Kenya"/>
  <link rel="preconnect" href="https://fonts.googleapis.com"/>
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin/>
  <script is:inline>
    (function(){
      var c=navigator.connection;
      if((c&&(c.saveData||['slow-2g','2g'].indexOf(c.effectiveType)>-1))||localStorage.getItem('axis-eco')==='on')
        document.documentElement.classList.add('low-data');
    })();
  </script>
</head>
<body>

<canvas id="fib-bg" aria-hidden="true" style="position:fixed;inset:0;width:100%;height:100%;pointer-events:none;z-index:0;opacity:.055;"></canvas>

<div class="mob-menu" id="mob-menu" role="navigation">
  <a href="/"           class="mob-link" aria-current={page==='home'       ?'page':undefined}>Home</a>
  <a href="/work"       class="mob-link" aria-current={page==='work'       ?'page':undefined}>Our Work</a>
  <a href="/assessment" class="mob-link" aria-current={page==='assessment' ?'page':undefined}>Assessment</a>
  <a href="/contact"    class="mob-link" aria-current={page==='contact'    ?'page':undefined}>Contact & FAQ</a>
  <a href="/assessment" class="btn-g" style="margin-top:4px;justify-content:center;">Start Free Assessment</a>
</div>

<header style="position:fixed;top:0;left:0;right:0;z-index:500;">
  <nav id="main-nav" style="height:54px;display:flex;align-items:center;justify-content:space-between;padding:0 clamp(16px,4vw,36px);background:rgba(6,14,8,.94);backdrop-filter:blur(22px);-webkit-backdrop-filter:blur(22px);border-bottom:1px solid var(--gb);">
    <a href="/" style="display:flex;align-items:center;gap:9px;text-decoration:none;font-family:var(--fm);font-size:.74rem;letter-spacing:.22em;color:var(--t1);">
      <canvas id="logo-c" width="24" height="24" aria-hidden="true"></canvas>
      AXIS
    </a>
    <div class="hide-mob" style="display:flex;gap:2px;background:rgba(255,255,255,.04);border:1px solid var(--gb);border-radius:8px;padding:3px;">
      <a href="/"           class="nav-link" aria-current={page==='home'       ?'page':undefined}>Home</a>
      <a href="/work"       class="nav-link" aria-current={page==='work'       ?'page':undefined}>Our Work</a>
      <a href="/assessment" class="nav-link" aria-current={page==='assessment' ?'page':undefined}>Assessment</a>
      <a href="/contact"    class="nav-link" aria-current={page==='contact'    ?'page':undefined}>Contact</a>
    </div>
    <div style="display:flex;align-items:center;gap:8px;">
      <a href="/assessment" class="btn-g hide-mob" style="font-size:.72rem;padding:8px 16px;">Free Assessment</a>
      <button class="ham" id="ham" onclick="toggleMob()" aria-label="Menu" aria-expanded="false">
        <span></span><span></span><span></span>
      </button>
    </div>
  </nav>
</header>

<main style="padding-top:54px;">
  <slot/>
</main>

<div class="float-dock" role="navigation" aria-label="Quick actions">
  <a href="/assessment" class="btn-g" style="font-size:.7rem;padding:8px 14px;">Assess</a>
  <a href="/contact"    class="btn-o" style="font-size:.7rem;padding:7px 12px;">Contact</a>
  <a href="/work"       class="btn-o" style="font-size:.7rem;padding:7px 12px;">Work</a>
</div>

<footer style="padding:clamp(32px,5vw,48px) clamp(20px,5vw,40px) clamp(20px,3vw,28px);border-top:1px solid var(--gb);position:relative;z-index:1;">
  <div id="fg" style="display:grid;grid-template-columns:1.1fr .8fr 1fr;gap:clamp(20px,4vw,40px);margin-bottom:clamp(24px,4vw,32px);">
    <div>
      <a href="/" style="display:flex;align-items:center;gap:8px;text-decoration:none;font-family:var(--fm);font-size:.72rem;letter-spacing:.2em;color:var(--t1);margin-bottom:12px;">
        <canvas id="flogo-c" width="20" height="20" aria-hidden="true"></canvas>AXIS
      </a>
      <p style="font-size:clamp(.76rem,.9vw,.82rem);font-weight:300;color:var(--t3);line-height:1.65;margin-bottom:12px;">Digital systems for Kenyan businesses.<br/>Mombasa · Nairobi · Kenya</p>
      <div style="display:flex;align-items:center;gap:7px;"><div class="dot"></div><span style="font-family:var(--fm);font-size:.54rem;color:var(--t3);letter-spacing:.08em;">ALL SYSTEMS LIVE</span></div>
    </div>
    <div>
      <p class="lbl" style="margin-bottom:10px;">Navigate</p>
      <a href="/"            class="footer-link">Home</a>
      <a href="/work"        class="footer-link">Our Work</a>
      <a href="/assessment"  class="footer-link">Free Assessment</a>
      <a href="/contact"     class="footer-link">Contact & FAQ</a>
    </div>
    <div>
      <p class="lbl" style="margin-bottom:10px;">Get Started</p>
      <p style="font-size:clamp(.76rem,.9vw,.8rem);font-weight:300;color:var(--t3);line-height:1.65;margin-bottom:14px;">Book a free assessment. We'll review your business and show you what's possible.</p>
      <a href="/assessment" class="btn-g" style="font-size:.7rem;padding:8px 16px;">Book Assessment</a>
    </div>
  </div>
  <div style="border-top:1px solid rgba(255,255,255,.05);padding-top:18px;display:flex;justify-content:space-between;align-items:center;flex-wrap:wrap;gap:10px;">
    <p style="font-family:var(--fm);font-size:clamp(.48rem,.6vw,.54rem);color:rgba(255,255,255,.18);letter-spacing:.05em;">© {new Date().getFullYear()} AXIS MEDIA AND WEB SERVICES · MOMBASA, KENYA</p>
    <p style="font-family:var(--fm);font-size:clamp(.48rem,.6vw,.54rem);color:rgba(255,255,255,.18);letter-spacing:.05em;">Built with precision.</p>
  </div>
</footer>

<script is:inline>
// Logo Fibonacci spiral
function drawLogo(id,s){
  var c=document.getElementById(id);if(!c)return;
  var x=c.getContext('2d'),cx=s/2,cy=s/2,PHI=1.618;
  x.clearRect(0,0,s,s);
  x.strokeStyle='#C9A84C';x.lineWidth=.85;
  x.beginPath();
  for(var a=0;a<Math.PI*4;a+=.06){
    var r=1.4*Math.pow(PHI,a/Math.PI/2);
    var px=cx+r*Math.cos(a-Math.PI/2),py=cy+r*Math.sin(a-Math.PI/2);
    a===0?x.moveTo(px,py):x.lineTo(px,py);
    if(r>s*.45)break;
  }
  x.stroke();
  x.strokeStyle='rgba(201,168,76,.5)';x.lineWidth=.7;
  x.beginPath();x.moveTo(cx,2);x.lineTo(s-2,s-2);x.lineTo(2,s-2);x.closePath();x.stroke();
}
drawLogo('logo-c',24);
drawLogo('flogo-c',20);

// Fibonacci background spirals
(function(){
  var c=document.getElementById('fib-bg');if(!c)return;
  var x=c.getContext('2d');
  function resize(){c.width=window.innerWidth;c.height=window.innerHeight;draw();}
  function spiral(cx,cy,u,col,a){
    x.strokeStyle=col;x.globalAlpha=a;x.lineWidth=.7;
    var s=0,b=u,ox=cx,oy=cy;
    var d=[[0,-1],[1,0],[0,1],[-1,0]];
    for(var i=0;i<11;i++){
      var r=b,dr=d[i%4];
      var ncx=ox+dr[0]*r,ncy=oy+dr[1]*r;
      x.beginPath();x.arc(ncx,ncy,r,i%4*Math.PI/2,(i%4+1)*Math.PI/2);x.stroke();
      ox=ncx;oy=ncy;var tmp=b;b=s+b;s=tmp;
      if(b>Math.max(c.width,c.height)*1.5)break;
    }
    x.globalAlpha=1;
  }
  function draw(){
    x.clearRect(0,0,c.width,c.height);
    spiral(c.width*.12,c.height*.18,8,'#C9A84C',.45);
    spiral(c.width*.88,c.height*.78,5,'#2D6B3F',.5);
    spiral(c.width*.5,c.height*.45,3,'#C9A84C',.15);
  }
  window.addEventListener('resize',resize,{passive:true});
  resize();
})();

// Mobile nav
window.toggleMob=function(){
  var h=document.getElementById('ham');
  var m=document.getElementById('mob-menu');
  var open=h.classList.toggle('open');
  m.classList.toggle('open',open);
  h.setAttribute('aria-expanded',String(open));
};
document.addEventListener('click',function(e){
  var h=document.getElementById('ham');
  var m=document.getElementById('mob-menu');
  if(h&&m&&!h.contains(e.target)&&!m.contains(e.target)){
    h.classList.remove('open');m.classList.remove('open');
    h.setAttribute('aria-expanded','false');
  }
});

// Nav scroll shadow
window.addEventListener('scroll',function(){
  var n=document.getElementById('main-nav');
  if(n)n.style.background=window.scrollY>20?'rgba(6,14,8,.97)':'rgba(6,14,8,.94)';
},{passive:true});

// Scroll reveal with Fibonacci delays
var FIB=[0,89,144,233,377,610];var ri=0;
var io=new IntersectionObserver(function(entries){
  entries.forEach(function(e){
    if(e.isIntersecting){
      var delay=FIB[ri%6];
      setTimeout(function(){e.target.classList.add('vis');},delay);
      ri++;io.unobserve(e.target);
    }
  });
},{threshold:.07,rootMargin:'0px 0px -20px 0px'});
document.querySelectorAll('.rv').forEach(function(el){io.observe(el);});

// Hero parallax at 1/phi ratio
window.addEventListener('scroll',function(){
  var hc=document.getElementById('hero-content');
  var hcanvas=document.getElementById('hero-canvas');
  if(hc)hc.style.transform='translateY('+(window.scrollY/1.618*.3)+'px)';
  if(hcanvas)hcanvas.style.transform='translateY('+(window.scrollY*.1)+'px)';
},{passive:true});

// Footer responsive
function rfg(){
  var g=document.getElementById('fg');if(!g)return;
  g.style.gridTemplateColumns=window.innerWidth<600?'1fr':window.innerWidth<900?'1fr 1fr':'1.1fr .8fr 1fr';
}
window.addEventListener('resize',rfg,{passive:true});rfg();

// Fibonacci cursor trail — desktop only, pointer:fine
if(window.matchMedia&&window.matchMedia('(pointer:fine)').matches&&
   !(window.matchMedia('(prefers-reduced-motion:reduce)').matches)){
  var PHI=1.618;
  var sizes=[8,5,3,2,1.3,0.8];
  var trails=sizes.map(function(s){
    var d=document.createElement('div');
    d.style.cssText='position:fixed;border-radius:50%;pointer-events:none;z-index:9000;transform:translate(-50%,-50%);width:'+(s*2)+'px;height:'+(s*2)+'px;background:rgba(201,168,76,'+Math.min(.3/s+.05,.25)+');transition:left '+(Math.round(s*60))+'ms ease,top '+(Math.round(s*60))+'ms ease;';
    document.body.appendChild(d);return d;
  });
  var mx=0,my=0;
  document.addEventListener('mousemove',function(e){mx=e.clientX;my=e.clientY;},{passive:true});
  (function animTrail(){
    trails.forEach(function(t,i){
      var a=i*Math.PI*2/PHI,r=i*3;
      t.style.left=(mx+r*Math.cos(a))+'px';
      t.style.top=(my+r*Math.sin(a))+'px';
    });
    requestAnimationFrame(animTrail);
  })();
}
</script>
</body>
</html>
