---
import BaseLayout from '../layouts/BaseLayout.astro';

const assets = [
  {
    slug: 'axis-manifesto',
    title: 'The AXIS Manifesto',
    subtitle: 'How Sovereign Infrastructure Is Built',
    pages: 38,
    description: 'The complete methodology document. System blueprints, vocabulary architecture, and the clinical framework AXIS uses for every infrastructure engagement.',
    free: true,
  },
  {
    slug: 'mpesa-integration-guide',
    title: 'M-Pesa Daraja Integration Guide',
    subtitle: 'STK Push, B2C & Callback Architecture',
    pages: 24,
    description: 'Step-by-step Daraja API implementation guide for Kenyan developers. Covers STK Push, C2B, B2C, and production deployment checklist.',
    free: false,
  },
  {
    slug: 'solid-vocabulary-lexicon',
    title: 'The Solid Vocabulary Lexicon',
    subtitle: '200 Authority Words for Digital Infrastructure',
    pages: 16,
    description: 'The complete AXIS vocabulary system. 200 Solid Words organized by context — web copy, proposal language, SEO schema, and client communication.',
    free: false,
  },
];
---

<BaseLayout
  title="Resource Vault"
  description="The AXIS Resource Vault — PDF guides, vocabulary lexicons, and infrastructure templates for Kenyan digital builders."
  page="vault"
>
  <section style="padding:100px 0 120px;">
    <div class="section-container">

      <div style="max-width:640px;margin-bottom:72px;">
        <p class="t-label" data-reveal style="margin-bottom:16px;">RESOURCE VAULT</p>
        <h1 class="t-display-lg" data-reveal data-reveal-delay="1">
          The <em style="color:var(--c-gold);">Archive</em> of Assets
        </h1>
        <p class="t-body" data-reveal data-reveal-delay="2" style="font-size:1.05rem;margin-top:16px;max-width:480px;">
          Practical infrastructure documents. Free to qualified builders. Email capture required for gated resources.
        </p>
      </div>

      <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(340px,1fr));gap:20px;">
        {assets.map(asset => (
          <div class="glass-card" data-reveal style="padding:36px;display:flex;flex-direction:column;justify-content:space-between;gap:24px;">
            <div>
              <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:16px;">
                <span style="font-family:var(--font-mono);font-size:0.65rem;letter-spacing:0.12em;color:rgba(255,255,255,0.3);text-transform:uppercase;">{asset.pages} pages</span>
                {asset.free
                  ? <span style="font-family:var(--font-mono);font-size:0.65rem;padding:3px 10px;background:rgba(79,255,176,0.1);border:1px solid rgba(79,255,176,0.25);border-radius:4px;color:var(--c-signal);">FREE</span>
                  : <span style="font-family:var(--font-mono);font-size:0.65rem;padding:3px 10px;background:rgba(201,168,76,0.08);border:1px solid rgba(201,168,76,0.2);border-radius:4px;color:var(--c-gold);">EMAIL GATE</span>
                }
              </div>
              <h2 style="font-family:var(--font-display);font-size:1.5rem;font-weight:400;color:rgba(255,255,255,0.95);margin-bottom:6px;">{asset.title}</h2>
              <p style="font-family:var(--font-mono);font-size:0.7rem;color:var(--c-gold);letter-spacing:0.08em;margin-bottom:14px;">{asset.subtitle}</p>
              <p class="t-body" style="font-size:0.875rem;">{asset.description}</p>
            </div>

            {asset.free
              ? (
                <a href={`/vault/axis-manifesto.pdf`} class="btn-primary" download style="justify-content:center;">
                  Download Free
                  <svg width="14" height="14" viewBox="0 0 14 14" fill="none"><path d="M7 2v7M4.5 6.5l2.5 3 2.5-3M2 11h10" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
                </a>
              ) : (
                <div>
                  <div style="display:flex;flex-direction:column;gap:8px;margin-bottom:12px;" data-vault-form={asset.slug} class="vault-form">
                    <input type="text"  class="input-field vault-name"  placeholder="Your name"  style="font-size:0.875rem;padding:10px 14px;" />
                    <input type="email" class="input-field vault-email" placeholder="Your email" style="font-size:0.875rem;padding:10px 14px;" />
                  </div>
                  <button
                    class="btn-ghost vault-submit"
                    data-slug={asset.slug}
                    style="width:100%;justify-content:center;"
                    onclick={`window.__vaultAccess('${asset.slug}', this)`}
                  >
                    Unlock & Download
                  </button>
                </div>
              )
            }
          </div>
        ))}
      </div>

    </div>
  </section>
</BaseLayout>

<script>
  window.__vaultAccess = async function (slug: string, btn: HTMLButtonElement) {
    const form  = btn.closest('[data-vault-form]') as HTMLElement || btn.parentElement!;
    const nameEl  = form.querySelector('.vault-name')  as HTMLInputElement;
    const emailEl = form.querySelector('.vault-email') as HTMLInputElement;
    const name  = nameEl?.value?.trim();
    const email = emailEl?.value?.trim();
    if (!name || !email) { alert('Enter your name and email to unlock.'); return; }

    btn.textContent = 'Processing…';
    btn.disabled    = true;

    try {
      const res  = await fetch('https://axismediaweb.up.railway.app/', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ name, email, asset: slug }),
      });
      const data = await res.json();
      if (data.signed_url) {
        window.open(data.signed_url, '_blank');
        btn.textContent = '✓ Downloading…';
      } else {
        btn.textContent = 'Retry';
        btn.disabled = false;
      }
    } catch (_) {
      btn.textContent = 'Error — Retry';
      btn.disabled = false;
    }
  };
</script>
