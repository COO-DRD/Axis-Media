---
import BaseLayout from '../layouts/BaseLayout.astro';

const pillars = [
  {
    id: '01',
    title: 'Infrastructure Audit',
    description: 'A clinical dissection of your existing digital footprint. We identify the precise points where authority leaks — broken funnels, absent schema, dead payment paths — and produce a Gap Report that becomes the blueprint for reconstruction.',
    signal: 'Gap Analysis',
    icon: 'audit',
  },
  {
    id: '02',
    title: 'Semantic Architecture',
    description: 'The language your systems use determines the audience they attract. We engineer a vocabulary architecture — Solid Words, Entity-First copy, and schema-backed metadata — that signals authority to both humans and machines.',
    signal: 'Vocabulary Layer',
    icon: 'semantic',
  },
  {
    id: '03',
    title: 'Persona-Led Content',
    description: 'The "Trapped Expert" demographic does not respond to marketing. They respond to recognition. Every content system AXIS builds speaks directly to the friction they feel — without naming it as a product pitch.',
    signal: 'Narrative Engine',
    icon: 'persona',
  },
  {
    id: '04',
    title: 'Service-First Funnels',
    description: 'A funnel built on generosity converts at a higher rate than one built on urgency. The Generosity Loop — free diagnoses, unpaywalled assets, open architecture — creates the trust debt that converts itself.',
    signal: 'Conversion System',
    icon: 'funnel',
  },
  {
    id: '05',
    title: 'The Maintenance Phase',
    description: 'Infrastructure that is not maintained is infrastructure that decays. AXIS operates an active Maintenance Phase: continuous latency monitoring, content velocity management, and quarterly schema reviews.',
    signal: 'Sovereign Continuity',
    icon: 'maintenance',
  },
];

const vocabularyShift = [
  { hollow: 'Digital Marketing',     solid: 'Authority Infrastructure' },
  { hollow: 'Website',               solid: 'Digital Twin' },
  { hollow: 'Social Media Posts',    solid: 'Narrative Installations' },
  { hollow: 'SEO',                   solid: 'Semantic Sovereignty' },
  { hollow: 'Lead Generation',       solid: 'Authority Capture' },
  { hollow: 'Landing Page',          solid: 'Intake Engine' },
  { hollow: 'Online Store',          solid: 'Revenue Architecture' },
  { hollow: 'Customer',              solid: 'System Beneficiary' },
  { hollow: 'Content Calendar',      solid: 'Velocity Protocol' },
  { hollow: 'Portfolio',             solid: 'Systems Archive' },
  { hollow: 'Contact Page',          solid: 'Vetting Interface' },
  { hollow: 'About Page',            solid: 'Proof Archive' },
];

const solutionsSchema = {
  '@type': 'Service',
  name: 'AXIS Infrastructure Methodology',
  provider: { '@type': 'Organization', name: 'AXIS Media and Web Services' },
  serviceType: 'Digital Infrastructure Engineering',
  areaServed: { '@type': 'Country', name: 'Kenya' },
  description: 'The five-pillar methodology for Sovereign Digital Infrastructure: Audit, Semantic Architecture, Persona-Led Content, Service-First Funnels, and Maintenance.',
};
---

<BaseLayout
  title="Infrastructure Methodology"
  description="The five pillars of Sovereign Digital Infrastructure from AXIS Media. Semantic Architecture, Persona-Led Content, and the Generosity Loop for Kenyan enterprises."
  schema={solutionsSchema}
  page="solutions"
>

  <!-- ── HERO ───────────────────────────────── -->
  <section style="padding:100px 0 80px;position:relative;overflow:hidden;">
    <div aria-hidden="true" style="position:absolute;top:0;left:0;right:0;height:1px;background:linear-gradient(to right,transparent,rgba(201,168,76,0.3),transparent);"></div>
    <div class="section-container">
      <div style="max-width:700px;">
        <p class="t-label" data-reveal style="margin-bottom:16px;">THE METHODOLOGY</p>
        <h1 class="t-display-xl" data-reveal data-reveal-delay="1">
          How AXIS<br/><em style="color:var(--c-gold);">Thinks.</em>
        </h1>
        <p class="t-body" data-reveal data-reveal-delay="2" style="font-size:1.1rem;max-width:540px;margin-top:20px;line-height:1.75;">
          The Sovereign Infrastructure model is not a service list. It is an epistemology — a precise way of diagnosing, designing, and deploying digital systems that do not merely exist but <em style="color:rgba(255,255,255,0.85);">produce.</em>
        </p>
      </div>
    </div>
  </section>

  <!-- ── 5 PILLARS ──────────────────────────── -->
  <section style="padding:40px 0 100px;">
    <div class="section-container">
      <div style="display:flex;flex-direction:column;gap:2px;">
        {pillars.map((pillar, idx) => (
          <div
            class="glass-card"
            data-reveal
            data-reveal-delay={String(idx % 3)}
            style="border-radius:12px;overflow:hidden;display:grid;grid-template-columns:80px 1fr auto;gap:0;align-items:stretch;"
          >
            <!-- Number -->
            <div style="background:rgba(201,168,76,0.04);border-right:1px solid rgba(255,255,255,0.06);display:flex;align-items:center;justify-content:center;padding:40px 0;">
              <span style="font-family:var(--font-display);font-size:2.4rem;font-weight:300;color:rgba(201,168,76,0.3);">{pillar.id}</span>
            </div>

            <!-- Content -->
            <div style="padding:40px 48px;">
              <p class="t-label" style="margin-bottom:10px;">{pillar.signal}</p>
              <h3 style="font-family:var(--font-display);font-size:1.9rem;font-weight:400;color:rgba(255,255,255,0.97);margin-bottom:14px;">{pillar.title}</h3>
              <p class="t-body">{pillar.description}</p>
            </div>

            <!-- Right accent -->
            <div style="width:4px;background:linear-gradient(to bottom,var(--c-gold),transparent);opacity:0.4;border-radius:0 12px 12px 0;"></div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ── VOCABULARY SHIFT TABLE ─────────────── -->
  <section style="padding:100px 0;background:rgba(201,168,76,0.02);border-top:1px solid var(--c-border);border-bottom:1px solid var(--c-border);">
    <div class="section-container">
      <div style="text-align:center;margin-bottom:64px;">
        <p class="t-label" data-reveal style="margin-bottom:12px;">THE VOCABULARY SHIFT</p>
        <h2 class="t-display-lg" data-reveal data-reveal-delay="1">
          Hollow Language vs.<br/><em style="color:var(--c-gold);">Solid Words</em>
        </h2>
        <p class="t-body" data-reveal data-reveal-delay="2" style="max-width:480px;margin:16px auto 0;">
          Competitors traffic in generic terminology. AXIS installs a lexicon that differentiates you before a sentence is finished.
        </p>
      </div>

      <div data-reveal style="overflow:hidden;border-radius:16px;border:1px solid var(--c-border);box-shadow:var(--shadow-glass-md);">
        <!-- Header -->
        <div style="display:grid;grid-template-columns:1fr 1fr;background:rgba(255,255,255,0.03);border-bottom:1px solid var(--c-border);">
          <div style="padding:20px 32px;border-right:1px solid var(--c-border);">
            <span style="font-family:var(--font-mono);font-size:0.7rem;letter-spacing:0.16em;text-transform:uppercase;color:rgba(255,255,255,0.35);">Generic — Hollow Language</span>
          </div>
          <div style="padding:20px 32px;">
            <span style="font-family:var(--font-mono);font-size:0.7rem;letter-spacing:0.16em;text-transform:uppercase;color:var(--c-gold);">AXIS — Solid Words</span>
          </div>
        </div>

        <!-- Rows -->
        {vocabularyShift.map((row, i) => (
          <div
            style={`display:grid;grid-template-columns:1fr 1fr;${i < vocabularyShift.length-1?'border-bottom:1px solid rgba(255,255,255,0.04);':''}`}
            class="vocab-row"
          >
            <div style="padding:18px 32px;border-right:1px solid rgba(255,255,255,0.04);display:flex;align-items:center;gap:12px;">
              <svg width="16" height="16" viewBox="0 0 16 16" fill="none"><path d="M4 8h8" stroke="rgba(255,255,255,0.2)" stroke-width="1.5" stroke-linecap="round"/><path d="M11 5l3 3-3 3" stroke="rgba(255,255,255,0.2)" stroke-width="1.5" stroke-linecap="round"/></svg>
              <span style="font-family:var(--font-body);font-size:0.9rem;color:rgba(255,255,255,0.35);text-decoration:line-through;text-decoration-color:rgba(255,255,255,0.15);">{row.hollow}</span>
            </div>
            <div style="padding:18px 32px;display:flex;align-items:center;gap:12px;background:rgba(201,168,76,0.02);">
              <svg width="16" height="16" viewBox="0 0 16 16" fill="none"><path d="M3 8h10" stroke="rgba(201,168,76,0.6)" stroke-width="1.5" stroke-linecap="round"/><path d="M10 5l3 3-3 3" stroke="rgba(201,168,76,0.6)" stroke-width="1.5" stroke-linecap="round"/></svg>
              <span style="font-family:var(--font-body);font-size:0.9rem;font-weight:500;color:rgba(255,255,255,0.88);">{row.solid}</span>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ── GENEROSITY LOOP DIAGRAM ─────────────── -->
  <section style="padding:100px 0;">
    <div class="section-container">
      <div style="text-align:center;margin-bottom:64px;">
        <p class="t-label" data-reveal style="margin-bottom:12px;">VISUAL LOGIC</p>
        <h2 class="t-display-md" data-reveal data-reveal-delay="1">
          The <em style="color:var(--c-gold);">Generosity Loop</em>
        </h2>
      </div>

      <div data-reveal class="glass-card" style="padding:56px;position:relative;">
        <!-- Diagram SVG -->
        <svg viewBox="0 0 900 320" style="width:100%;max-width:900px;display:block;margin:0 auto;" xmlns="http://www.w3.org/2000/svg">
          <!-- Connections -->
          <defs>
            <marker id="arrowGold" markerWidth="8" markerHeight="8" refX="6" refY="3" orient="auto">
              <path d="M0,0 L0,6 L8,3 z" fill="rgba(201,168,76,0.7)"/>
            </marker>
          </defs>

          <path d="M 160 160 Q 225 80  290 160" stroke="rgba(201,168,76,0.35)" stroke-width="1.5" fill="none" stroke-dasharray="6,4" marker-end="url(#arrowGold)"/>
          <path d="M 430 160 Q 495 80  560 160" stroke="rgba(201,168,76,0.35)" stroke-width="1.5" fill="none" stroke-dasharray="6,4" marker-end="url(#arrowGold)"/>
          <path d="M 700 160 Q 770 80  840 160" stroke="rgba(201,168,76,0.35)" stroke-width="1.5" fill="none" stroke-dasharray="6,4" marker-end="url(#arrowGold)"/>
          <!-- Return loop -->
          <path d="M 840 200 Q 500 300 80 200" stroke="rgba(79,255,176,0.25)" stroke-width="1" fill="none" stroke-dasharray="4,6" marker-end="url(#arrowGold)"/>

          <!-- Node: Expert -->
          <rect x="10" y="120" width="150" height="80" rx="10" fill="rgba(201,168,76,0.06)" stroke="rgba(201,168,76,0.25)" stroke-width="1"/>
          <text x="85" y="152" text-anchor="middle" fill="rgba(255,255,255,0.8)" font-family="'DM Sans',sans-serif" font-size="12" font-weight="500">Trapped Expert</text>
          <text x="85" y="170" text-anchor="middle" fill="rgba(255,255,255,0.4)" font-family="'JetBrains Mono',monospace" font-size="9">Invisible Authority</text>
          <text x="85" y="186" text-anchor="middle" fill="rgba(255,255,255,0.4)" font-family="'JetBrains Mono',monospace" font-size="9">→ discovers Audit</text>

          <!-- Node: Gift -->
          <rect x="280" y="120" width="150" height="80" rx="10" fill="rgba(201,168,76,0.06)" stroke="rgba(201,168,76,0.25)" stroke-width="1"/>
          <text x="355" y="152" text-anchor="middle" fill="rgba(255,255,255,0.8)" font-family="'DM Sans',sans-serif" font-size="12" font-weight="500">Free Gift Delivered</text>
          <text x="355" y="170" text-anchor="middle" fill="rgba(255,255,255,0.4)" font-family="'JetBrains Mono',monospace" font-size="9">Gap Report PDF</text>
          <text x="355" y="186" text-anchor="middle" fill="rgba(255,255,255,0.4)" font-family="'JetBrains Mono',monospace" font-size="9">Trust Debt Created</text>

          <!-- Node: Score -->
          <rect x="550" y="120" width="150" height="80" rx="10" fill="rgba(79,255,176,0.05)" stroke="rgba(79,255,176,0.2)" stroke-width="1"/>
          <text x="625" y="152" text-anchor="middle" fill="rgba(255,255,255,0.8)" font-family="'DM Sans',sans-serif" font-size="12" font-weight="500">Score Calculated</text>
          <text x="625" y="170" text-anchor="middle" fill="rgba(255,255,255,0.4)" font-family="'JetBrains Mono',monospace" font-size="9">Authority Index</text>
          <text x="625" y="186" text-anchor="middle" fill="rgba(255,255,255,0.4)" font-family="'JetBrains Mono',monospace" font-size="9">→ Route Determined</text>

          <!-- Node: Convert -->
          <rect x="820" y="120" width="70" height="80" rx="10" fill="rgba(224,92,58,0.08)" stroke="rgba(224,92,58,0.3)" stroke-width="1"/>
          <text x="855" y="155" text-anchor="middle" fill="rgba(255,255,255,0.8)" font-family="'DM Sans',sans-serif" font-size="11" font-weight="500">Convert</text>
          <text x="855" y="172" text-anchor="middle" fill="rgba(255,255,255,0.4)" font-family="'JetBrains Mono',monospace" font-size="8">M-Pesa</text>
          <text x="855" y="185" text-anchor="middle" fill="rgba(255,255,255,0.4)" font-family="'JetBrains Mono',monospace" font-size="8">STK Push</text>

          <!-- Return label -->
          <text x="450" y="295" text-anchor="middle" fill="rgba(79,255,176,0.5)" font-family="'JetBrains Mono',monospace" font-size="9" letter-spacing="0.1em">PERPETUAL TRUST LOOP</text>
        </svg>
      </div>

      <!-- CEO Freedom Engine -->
      <div style="margin-top:64px;text-align:center;">
        <p class="t-label" data-reveal style="margin-bottom:12px;">SYSTEM OUTPUT</p>
        <h2 class="t-display-md" data-reveal data-reveal-delay="1">
          The <em style="color:var(--c-signal);">CEO Freedom</em> Engine
        </h2>
        <p class="t-body" data-reveal data-reveal-delay="2" style="max-width:520px;margin:16px auto 0;">
          When the Generosity Loop is installed and the Maintenance Phase is active, the founder is removed from the conversion chain. Revenue is generated by infrastructure, not labor.
        </p>
      </div>

      <div data-reveal style="display:grid;grid-template-columns:repeat(3,1fr);gap:24px;margin-top:48px;">
        {[
          { step: '1', title: 'Infrastructure Installed', body: 'AXIS builds and deploys the complete system — audit engine, funnels, M-Pesa rails, and content velocity.', color: 'var(--c-gold)' },
          { step: '2', title: 'System Operates Autonomously', body: 'Leads are captured, scored, nurtured, and converted without manual intervention. Telegram notifies the CEO of high-value signals.', color: 'var(--c-signal)' },
          { step: '3', title: 'CEO Presence is Strategic', body: 'The CEO\'s attention is reserved for the 5% of decisions that require it. The other 95% is infrastructure.', color: 'var(--c-ember)' },
        ].map(item => (
          <div class="glass-card" style="padding:36px;">
            <div style={`width:40px;height:40px;border-radius:50%;background:rgba(255,255,255,0.04);border:1px solid ${item.color};display:flex;align-items:center;justify-content:center;margin-bottom:20px;`}>
              <span style={`font-family:var(--font-mono);font-size:0.8rem;color:${item.color};`}>{item.step}</span>
            </div>
            <h3 style="font-family:var(--font-display);font-size:1.4rem;color:rgba(255,255,255,0.95);margin-bottom:10px;">{item.title}</h3>
            <p class="t-body" style="font-size:0.9rem;">{item.body}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ── CTA ────────────────────────────────── -->
  <section style="padding:80px 0 120px;">
    <div class="section-container" style="text-align:center;">
      <div class="glass-card" data-reveal style="max-width:640px;margin:0 auto;padding:56px;background:linear-gradient(135deg,rgba(201,168,76,0.06) 0%,rgba(20,20,23,0.9) 100%);">
        <p class="t-label" style="margin-bottom:12px;">NEXT NODE</p>
        <h2 style="font-family:var(--font-display);font-size:2.2rem;color:rgba(255,255,255,0.97);margin-bottom:16px;">
          See the Methodology<br/><em style="color:var(--c-gold);">in Production</em>
        </h2>
        <p class="t-body" style="margin-bottom:32px;">
          The Systems Archive documents every infrastructure deployment — with full anatomy, stack disclosure, and live access.
        </p>
        <div style="display:flex;gap:12px;justify-content:center;flex-wrap:wrap;">
          <a href="/archive" class="btn-primary">Review Infrastructure Archive</a>
          <a href="/initiate" class="btn-ghost">Begin Intake Vetting</a>
        </div>
      </div>
    </div>
  </section>

</BaseLayout>

<style>
  .vocab-row:hover {
    background: rgba(201,168,76,0.02);
  }
</style>
