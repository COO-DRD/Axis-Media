---
import BaseLayout from '../layouts/BaseLayout.astro';

const intakeSteps = [
  {
    id: 1,
    label: 'SCALE VERIFICATION',
    question: 'What is your current monthly business revenue?',
    type: 'radio',
    options: [
      { label: 'Under KES 100K',      score: 1 },
      { label: 'KES 100K – 500K',     score: 2 },
      { label: 'KES 500K – 2M',       score: 3 },
      { label: 'KES 2M+',             score: 4 },
    ],
  },
  {
    id: 2,
    label: 'BOTTLENECK ANALYSIS',
    question: 'Where does your primary operational friction live?',
    type: 'radio',
    options: [
      { label: 'I am losing time to manual processes',      score: 2 },
      { label: 'I am losing revenue to absent technology',  score: 3 },
      { label: 'I lack an authority digital presence',      score: 2 },
      { label: 'All three simultaneously',                  score: 4 },
    ],
  },
  {
    id: 3,
    label: 'COMMITMENT DECLARATION',
    question: 'How do you relate to the CEO Freedom model?',
    type: 'radio',
    options: [
      { label: 'I have not considered it',                  score: 1 },
      { label: 'I am interested but cautious',              score: 2 },
      { label: 'I actively want this outcome',              score: 3 },
      { label: 'I am ready to invest in building it',       score: 4 },
    ],
  },
];
---

<BaseLayout
  title="Initiate — Begin the Vetting"
  description="The AXIS intake vetting. Multi-step qualification for infrastructure engagements. M-Pesa Deep-Dive Audit available. Mombasa & Nairobi, Kenya."
  page="initiate"
>

  <!-- Hero -->
  <section style="padding:100px 0 60px;position:relative;">
    <div aria-hidden="true" style="position:absolute;top:0;left:0;right:0;height:1px;background:linear-gradient(to right,transparent,rgba(224,92,58,0.4),transparent);"></div>
    <div class="section-container">
      <div style="max-width:640px;">
        <p class="t-label" data-reveal style="margin-bottom:16px;color:var(--c-ember);">VETTING INTERFACE</p>
        <h1 class="t-display-xl" data-reveal data-reveal-delay="1">
          Not Everyone<br/><em style="color:var(--c-gold);">Gets In.</em>
        </h1>
        <p class="t-body" data-reveal data-reveal-delay="2" style="font-size:1.05rem;max-width:500px;margin-top:20px;">
          AXIS takes engagements selectively. This three-step vetting process determines whether a partnership can produce the outcomes both parties deserve.
        </p>
      </div>
    </div>
  </section>

  <!-- Main Gate: Two-Column -->
  <section style="padding:40px 0 120px;">
    <div class="section-container">
      <div style="display:grid;grid-template-columns:1fr 420px;gap:48px;align-items:start;" class="intake-layout">

        <!-- Left: Intake Form -->
        <div>
          <div class="glass-card" id="intake-tool" style="padding:48px;position:relative;overflow:hidden;">
            <div class="scan-line"></div>

            <!-- Progress -->
            <div style="display:flex;align-items:center;gap:6px;margin-bottom:40px;" id="intake-progress">
              {intakeSteps.map((s, i) => (
                <div style="display:flex;align-items:center;gap:6px;">
                  <div data-intake-dot={s.id} style={`height:6px;border-radius:3px;transition:all 0.3s;${i===0?'width:40px;background:var(--c-gold);':'width:24px;background:rgba(255,255,255,0.12);'}`}></div>
                  {i < intakeSteps.length-1 && <div style="width:8px;height:1px;background:rgba(255,255,255,0.1);"></div>}
                </div>
              ))}
            </div>

            <!-- Steps -->
            {intakeSteps.map((step, idx) => (
              <div data-intake-step={step.id} style={`display:${idx===0?'block':'none'};`}>
                <p class="t-label" style="margin-bottom:8px;color:var(--c-ember);">
                  {step.label} · {step.id}/3
                </p>
                <h2 style="font-family:var(--font-display);font-size:1.7rem;color:rgba(255,255,255,0.97);margin-bottom:28px;">{step.question}</h2>
                <div style="display:flex;flex-direction:column;gap:10px;">
                  {step.options.map(opt => (
                    <label class="intake-option" style="display:flex;align-items:center;gap:14px;padding:16px 20px;background:rgba(255,255,255,0.02);border:1px solid rgba(255,255,255,0.07);border-radius:10px;cursor:pointer;transition:all 0.2s;user-select:none;">
                      <input
                        type="radio"
                        name={`intake-${step.id}`}
                        value={opt.score}
                        style="accent-color:var(--c-gold);width:16px;height:16px;"
                      />
                      <span style="font-family:var(--font-body);font-size:0.95rem;color:rgba(255,255,255,0.75);">{opt.label}</span>
                      <!-- Score hidden from display but present in DOM -->
                      <span style="display:none;" data-score={opt.score}></span>
                    </label>
                  ))}
                </div>
              </div>
            ))}

            <!-- Contact Details -->
            <div data-intake-step="4" style="display:none;">
              <p class="t-label" style="margin-bottom:8px;color:var(--c-signal);">FINAL STEP</p>
              <h2 style="font-family:var(--font-display);font-size:1.7rem;color:rgba(255,255,255,0.97);margin-bottom:12px;">Identify Yourself</h2>
              <p class="t-body" style="font-size:0.9rem;margin-bottom:28px;">This information is used solely to prepare your vetting outcome and route you appropriately.</p>
              <div style="display:flex;flex-direction:column;gap:14px;">
                <input type="text"  id="intake-name"    class="input-field" placeholder="Full name" autocomplete="name" />
                <input type="email" id="intake-email"   class="input-field" placeholder="Business email" autocomplete="email" />
                <input type="tel"   id="intake-phone"   class="input-field" placeholder="Phone / WhatsApp (for M-Pesa)" autocomplete="tel" />
                <input type="url"   id="intake-website" class="input-field" placeholder="Current website (if any)" autocomplete="url" />
              </div>
            </div>

            <!-- Nav -->
            <div style="display:flex;justify-content:space-between;align-items:center;margin-top:36px;" id="intake-nav">
              <button id="intake-back" class="btn-ghost" style="display:none;" onclick="window.__intakeNav(-1)">← Back</button>
              <div></div>
              <button id="intake-next" class="btn-primary" onclick="window.__intakeNav(1)">
                Continue
                <svg width="14" height="14" viewBox="0 0 14 14" fill="none"><path d="M3 7h8M7.5 4l3 3-3 3" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
              </button>
            </div>

            <!-- Low Score Result: Gift Redirect -->
            <div id="intake-low-score" style="display:none;text-align:center;padding:32px 0;">
              <div style="width:56px;height:56px;border-radius:50%;background:rgba(201,168,76,0.1);border:1px solid rgba(201,168,76,0.3);display:flex;align-items:center;justify-content:center;margin:0 auto 20px;">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none"><path d="M12 5v8M12 16v2" stroke="#C9A84C" stroke-width="2" stroke-linecap="round"/></svg>
              </div>
              <h3 style="font-family:var(--font-display);font-size:1.6rem;color:rgba(255,255,255,0.95);margin-bottom:10px;">A Gift, First.</h3>
              <p class="t-body" style="font-size:0.9rem;margin-bottom:24px;">
                Your current scale suggests the best next move is the AXIS Manifesto. Build the foundation, then return for the full engagement.
              </p>
              <a href="/#gift" class="btn-primary">Collect Your Gift</a>
            </div>

            <!-- High Score Result: Calendly + M-Pesa -->
            <div id="intake-high-score" style="display:none;">
              <div style="text-align:center;padding:0 0 32px;">
                <div style="width:56px;height:56px;border-radius:50%;background:rgba(79,255,176,0.1);border:1px solid rgba(79,255,176,0.3);display:flex;align-items:center;justify-content:center;margin:0 auto 20px;">
                  <svg width="24" height="24" viewBox="0 0 24 24" fill="none"><path d="M5 12l5 5L19 7" stroke="#4FFFB0" stroke-width="2" stroke-linecap="round"/></svg>
                </div>
                <h3 style="font-family:var(--font-display);font-size:1.8rem;color:var(--c-signal);margin-bottom:8px;">Authority Confirmed.</h3>
                <p class="t-body" style="font-size:0.9rem;">Your infrastructure profile qualifies for a full AXIS engagement. Schedule your Deep-Dive Audit or initiate payment via M-Pesa.</p>
              </div>

              <!-- Calendly placeholder (hydrates as Island) -->
              <div id="calendly-mount" style="height:480px;background:rgba(255,255,255,0.02);border:1px solid var(--c-border);border-radius:12px;display:flex;align-items:center;justify-content:center;margin-bottom:24px;">
                <div style="text-align:center;">
                  <p class="t-label" style="margin-bottom:8px;">SCHEDULING ENGINE</p>
                  <p class="t-body" style="font-size:0.85rem;">Calendly booking widget — loads on qualification</p>
                  <a href="https://calendly.com/axis-media/deep-dive" target="_blank" rel="noopener" class="btn-ghost" style="margin-top:16px;display:inline-flex;">
                    Open Scheduler Directly
                  </a>
                </div>
              </div>

              <!-- M-Pesa Pre-Payment -->
              <div id="mpesa" style="padding:28px;background:rgba(79,255,176,0.04);border:1px solid rgba(79,255,176,0.15);border-radius:12px;">
                <p class="t-label" style="margin-bottom:8px;color:var(--c-signal);">M-PESA DEEP-DIVE AUDIT</p>
                <p style="font-family:var(--font-display);font-size:1.5rem;color:rgba(255,255,255,0.95);margin-bottom:4px;">KES 15,000</p>
                <p class="t-body" style="font-size:0.85rem;margin-bottom:20px;">Pre-pay for the 3-hour Deep-Dive Infrastructure Audit via M-Pesa STK Push. Immediate confirmation.</p>
                <div style="display:flex;gap:10px;flex-wrap:wrap;">
                  <input type="tel" id="mpesa-phone" class="input-field" placeholder="254712345678" style="flex:1;min-width:200px;" />
                  <button id="mpesa-btn" class="btn-signal" onclick="window.__initiateMpesa()" style="white-space:nowrap;">
                    <svg width="16" height="16" viewBox="0 0 16 16" fill="none"><path d="M8 2v5l3 2" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/><circle cx="8" cy="8" r="6" stroke="currentColor" stroke-width="1.5"/></svg>
                    Send STK Push
                  </button>
                </div>
                <div id="mpesa-status" style="margin-top:12px;display:none;font-family:var(--font-mono);font-size:0.75rem;color:var(--c-signal);"></div>
              </div>
            </div>

          </div>
        </div>

        <!-- Right: Trust Signals -->
        <div style="display:flex;flex-direction:column;gap:20px;position:sticky;top:96px;">

          <!-- What happens next -->
          <div class="glass-panel" style="padding:32px;">
            <p class="t-label" style="margin-bottom:16px;">WHAT HAPPENS NEXT</p>
            <div style="display:flex;flex-direction:column;gap:16px;">
              {[
                { n:'1', text:'You complete the 3-step vetting. Your Authority Score is calculated instantly.' },
                { n:'2', text:'High scores receive the scheduling engine and M-Pesa payment option.' },
                { n:'3', text:'Lower scores receive the AXIS Manifesto to build the foundation first.' },
                { n:'4', text:'AXIS reviews all qualified submissions within 24 hours.' },
              ].map(item => (
                <div style="display:flex;gap:14px;align-items:flex-start;">
                  <div style="width:24px;height:24px;border-radius:50%;background:rgba(201,168,76,0.1);border:1px solid rgba(201,168,76,0.25);display:flex;align-items:center;justify-content:center;flex-shrink:0;margin-top:2px;">
                    <span style="font-family:var(--font-mono);font-size:0.65rem;color:var(--c-gold);">{item.n}</span>
                  </div>
                  <p style="font-family:var(--font-body);font-size:0.875rem;font-weight:300;color:rgba(255,255,255,0.65);line-height:1.6;">{item.text}</p>
                </div>
              ))}
            </div>
          </div>

          <!-- Trust Signal: Metrics -->
          <div class="glass-panel" style="padding:28px;">
            <p class="t-label" style="margin-bottom:16px;">VETTING METRICS</p>
            <div style="display:flex;flex-direction:column;gap:12px;">
              {[
                { label:'Applications received this quarter', value:'23' },
                { label:'Engagements accepted',               value:'7'  },
                { label:'Acceptance rate',                    value:'30%'},
              ].map(m => (
                <div style="display:flex;justify-content:space-between;padding-bottom:12px;border-bottom:1px solid rgba(255,255,255,0.05);">
                  <span style="font-family:var(--font-body);font-size:0.8rem;color:rgba(255,255,255,0.45);">{m.label}</span>
                  <span style="font-family:var(--font-display);font-size:1.2rem;font-weight:300;color:var(--c-gold);">{m.value}</span>
                </div>
              ))}
            </div>
          </div>

          <!-- Security note -->
          <div style="padding:20px 24px;background:rgba(255,255,255,0.01);border:1px solid rgba(255,255,255,0.06);border-radius:10px;">
            <div style="display:flex;align-items:center;gap:10px;margin-bottom:8px;">
              <svg width="16" height="16" viewBox="0 0 16 16" fill="none"><path d="M8 2L3 5v4c0 3 2.5 5 5 6 2.5-1 5-3 5-6V5L8 2z" stroke="rgba(255,255,255,0.3)" stroke-width="1.2"/></svg>
              <span style="font-family:var(--font-mono);font-size:0.65rem;letter-spacing:0.12em;color:rgba(255,255,255,0.35);text-transform:uppercase;">Data Integrity</span>
            </div>
            <p style="font-family:var(--font-body);font-size:0.8rem;color:rgba(255,255,255,0.4);line-height:1.6;">
              All submitted data is stored in a private Supabase instance. M-Pesa transactions are processed through Safaricom Daraja. No third-party data brokers.
            </p>
          </div>

          <!-- Back links -->
          <div style="display:flex;flex-direction:column;gap:8px;">
            <a href="/solutions" style="font-family:var(--font-mono);font-size:0.7rem;letter-spacing:0.1em;color:rgba(255,255,255,0.35);text-decoration:none;transition:color 0.15s;" onmouseover="this.style.color='rgba(255,255,255,0.7)'" onmouseout="this.style.color='rgba(255,255,255,0.35)'">
              → Review Infrastructure Methodology
            </a>
            <a href="/archive" style="font-family:var(--font-mono);font-size:0.7rem;letter-spacing:0.1em;color:rgba(255,255,255,0.35);text-decoration:none;transition:color 0.15s;" onmouseover="this.style.color='rgba(255,255,255,0.7)'" onmouseout="this.style.color='rgba(255,255,255,0.35)'">
              → Review Infrastructure Archive
            </a>
          </div>
        </div>

      </div>
    </div>
  </section>

</BaseLayout>

<style>
  @media (max-width: 960px) {
    .intake-layout { grid-template-columns: 1fr !important; }
  }
  .intake-option:hover {
    border-color: rgba(224,92,58,0.3) !important;
    background: rgba(224,92,58,0.03) !important;
  }
</style>

<script>
  let intakeStep  = 1;
  let totalScore  = 0;

  window.__intakeNav = function (dir: number) {
    // Collect current selection
    const radioInStep = document.querySelector(
      `[data-intake-step="${intakeStep}"] input[type="radio"]:checked`
    ) as HTMLInputElement | null;

    if (dir === 1 && intakeStep <= 3) {
      if (!radioInStep) { highlightRequired(); return; }
      totalScore += parseInt(radioInStep.value, 10);
    }

    if (intakeStep === 3 && dir === 1) {
      // Advance to contact details
      showStep(4);
      intakeStep = 4;
      const nextBtn = document.getElementById('intake-next') as HTMLButtonElement;
      if (nextBtn) { nextBtn.textContent = 'Submit Application'; nextBtn.onclick = submitIntake; }
      updateProgress();
      return;
    }

    if (intakeStep === 4 && dir === 1) { submitIntake(); return; }

    const nextStep = intakeStep + dir;
    if (nextStep < 1) return;
    showStep(nextStep);
    intakeStep = nextStep;
    updateProgress();
  };

  function showStep(id: number) {
    document.querySelectorAll('[data-intake-step]').forEach(el => {
      (el as HTMLElement).style.display = 'none';
    });
    const el = document.querySelector(`[data-intake-step="${id}"]`) as HTMLElement;
    if (el) el.style.display = 'block';
  }

  function updateProgress() {
    const backBtn = document.getElementById('intake-back') as HTMLElement;
    if (backBtn) backBtn.style.display = intakeStep > 1 ? 'block' : 'none';

    for (let i = 1; i <= 3; i++) {
      const dot = document.querySelector(`[data-intake-dot="${i}"]`) as HTMLElement;
      if (!dot) continue;
      if (i < intakeStep) {
        dot.style.width = '40px';
        dot.style.background = 'rgba(79,255,176,0.5)';
      } else if (i === intakeStep) {
        dot.style.width = '40px';
        dot.style.background = 'var(--c-gold)';
      } else {
        dot.style.width = '24px';
        dot.style.background = 'rgba(255,255,255,0.12)';
      }
    }
  }

  function highlightRequired() {
    const stepEl = document.querySelector(`[data-intake-step="${intakeStep}"]`) as HTMLElement;
    if (!stepEl) return;
    stepEl.style.animation = 'none';
    stepEl.style.outline = '1px solid rgba(224,92,58,0.4)';
    stepEl.style.borderRadius = '8px';
    setTimeout(() => { stepEl.style.outline = 'none'; }, 1200);
  }

  async function submitIntake() {
    const name    = (document.getElementById('intake-name')    as HTMLInputElement)?.value?.trim();
    const email   = (document.getElementById('intake-email')   as HTMLInputElement)?.value?.trim();
    const phone   = (document.getElementById('intake-phone')   as HTMLInputElement)?.value?.trim();
    const website = (document.getElementById('intake-website') as HTMLInputElement)?.value?.trim();

    if (!name || !email) { alert('Please enter your name and email.'); return; }

    const nextBtn = document.getElementById('intake-next') as HTMLButtonElement;
    if (nextBtn) { nextBtn.textContent = 'Evaluating…'; nextBtn.disabled = true; }

    try {
      await fetch('/api/v1/audit', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ name, email, phone, website, authority_score: totalScore, source: 'initiate' }),
      });
    } catch (_) { /* graceful — result shown regardless */ }

    // Hide form elements
    const nav = document.getElementById('intake-nav') as HTMLElement;
    if (nav) nav.style.display = 'none';

    document.querySelectorAll('[data-intake-step]').forEach(el => {
      (el as HTMLElement).style.display = 'none';
    });
    const progress = document.getElementById('intake-progress') as HTMLElement;
    if (progress) progress.style.display = 'none';

    // Score threshold: 9+ = high, <9 = low
    if (totalScore >= 9) {
      const high = document.getElementById('intake-high-score') as HTMLElement;
      if (high) high.style.display = 'block';
    } else {
      const low = document.getElementById('intake-low-score') as HTMLElement;
      if (low) low.style.display = 'block';
    }
  }

  // M-Pesa STK Push
  window.__initiateMpesa = async function () {
    const phone = (document.getElementById('mpesa-phone') as HTMLInputElement)?.value?.trim();
    const statusEl = document.getElementById('mpesa-status') as HTMLElement;
    const btn = document.getElementById('mpesa-btn') as HTMLButtonElement;

    if (!phone || phone.length < 10) {
      if (statusEl) { statusEl.style.display = 'block'; statusEl.textContent = 'Enter a valid phone number (e.g. 254712345678)'; statusEl.style.color = 'var(--c-ember)'; }
      return;
    }

    btn.disabled = true;
    btn.textContent = 'Initiating STK Push…';
    if (statusEl) { statusEl.style.display = 'block'; statusEl.style.color = 'var(--c-signal)'; statusEl.textContent = 'Sending STK push to your phone…'; }

    try {
      const res = await fetch('/api/v1/daraja/initiate', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ phone, amount: 15000, description: 'AXIS Deep-Dive Audit' }),
      });
      const data = await res.json();
      if (data.success) {
        statusEl.textContent = '✓ STK push sent. Check your phone and enter your M-Pesa PIN.';
      } else {
        statusEl.style.color = 'var(--c-ember)';
        statusEl.textContent = 'Push failed. Please retry or contact AXIS directly.';
        btn.disabled = false;
        btn.textContent = 'Retry STK Push';
      }
    } catch (_) {
      statusEl.style.color = 'var(--c-ember)';
      statusEl.textContent = 'Network error. Please retry.';
      btn.disabled = false;
      btn.textContent = 'Retry STK Push';
    }
  };
</script>
