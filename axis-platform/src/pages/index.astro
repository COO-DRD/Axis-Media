<script is:inline>
// Hero canvas
(function(){
  var c=document.getElementById('hero-canvas');if(!c)return;
  var PHI=1.618;
  function draw(){
    var w=c.offsetWidth,h=c.offsetHeight;c.width=w;c.height=h;
    var x=c.getContext('2d');
    x.strokeStyle='rgba(201,168,76,.08)';x.lineWidth=1;
    var rw=Math.min(w,h)*.5,rh=rw/PHI,rx=w*.08,ry=h*.12;
    for(var i=0;i<6;i++){x.strokeRect(rx,ry,rw,rh);rh=rw/PHI;rw=rh;rx+=rw*.04;ry+=rh*.04;}
    x.strokeStyle='rgba(201,168,76,.09)';x.lineWidth=1.2;
    x.beginPath();var cx=w*.78,cy=h*.5;
    for(var a=0;a<Math.PI*6;a+=.04){
      var r=3*Math.pow(PHI,a/Math.PI/2);
      var px=cx+r*Math.cos(a),py=cy+r*Math.sin(a);
      a===0?x.moveTo(px,py):x.lineTo(px,py);
      if(r>Math.max(w,h))break;
    }
    x.stroke();
    x.fillStyle='rgba(201,168,76,.2)';
    [1,1,2,3,5,8,13,21,34].forEach(function(f,i){
      var a=i*Math.PI/PHI;
      x.beginPath();x.arc(w/2+f*Math.cos(a)*5,h/2+f*Math.sin(a)*3.5,Math.min(f*.18+.5,3),0,Math.PI*2);x.fill();
    });
  }
  window.addEventListener('resize',draw,{passive:true});
  setTimeout(draw,50);
})();

// Fib small canvas
(function(){
  var c=document.getElementById('fib-sm');if(!c)return;
  function draw(){
    var w=c.offsetWidth,h=c.offsetHeight;
    c.width=w*2;c.height=h*2;
    var x=c.getContext('2d');x.scale(2,2);
    var u=Math.min(w,h)/50,cx=w/2,cy=h/2;
    [[cx,cy-u,u],[cx-u,cy-u,u],[cx-u,cy-2*u,u*2],[cx,cy-u*4,u*3],[cx-u*5,cy-u*5,u*5],[cx-u*5,cy+u*3,u*8]].forEach(function(r,i){
      x.strokeStyle=i%2?'rgba(45,107,63,.35)':'rgba(201,168,76,.22)';x.lineWidth=.7;
      x.strokeRect(r[0],r[1],r[2],r[2]);
    });
    x.strokeStyle='rgba(201,168,76,.55)';x.lineWidth=1.1;
    [[cx+u,cy,u,Math.PI,1.5*Math.PI],[cx-u,cy-u,u,0,.5*Math.PI],[cx-u,cy+u,u*2,1.5*Math.PI,2*Math.PI],[cx+u*3,cy-u,u*3,.5*Math.PI,Math.PI],[cx+u*3,cy+u*7,u*5,Math.PI,1.5*Math.PI]].forEach(function(a){
      x.beginPath();x.arc(a[0],a[1],a[2],a[3],a[4]);x.stroke();
    });
    x.fillStyle='rgba(201,168,76,.38)';
    x.font=(u*.7)+'px JetBrains Mono,monospace';x.textAlign='center';
    x.fillText('φ = 1.618…',cx+u*8,cy-u*8);
  }
  window.addEventListener('resize',function(){setTimeout(draw,80);},{passive:true});
  setTimeout(draw,80);
})();

// Lead capture
window.claimReport=function(){
  var email=document.getElementById('report-email').value.trim();
  if(!email||!email.includes('@')){alert('Enter a valid email to receive the report.');return;}
  fetch('https://axismediaweb.up.railway.app/',{
    method:'POST',
    headers:{'Content-Type':'application/json'},
    body:JSON.stringify({email:email,source:'report_download',name:'Report Request'})
  }).catch(function(){});
  document.getElementById('report-form').style.display='none';
  document.getElementById('report-success').style.display='block';
};
</script>
