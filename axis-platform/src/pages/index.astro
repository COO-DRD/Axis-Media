---
import BaseLayout from '../layouts/BaseLayout.astro';

const services = [
  {
    icon:'grid',
    title:'Authority Infrastructure',
    old:'Professional Website',
    desc:'A precision-built digital command centre that positions you as the undisputed authority in your market — and converts visitors into clients before they speak to a competitor.',
  },
  {
    icon:'pay',
    title:'Liquidity Automation',
    old:'M-Pesa Payments',
    desc:'Your revenue pipeline runs 24/7. M-Pesa STK Push, automated receipts, instant notifications. Money moves the moment a client decides — no manual intervention, no leakage.',
  },
  {
    icon:'grow',
    title:'Client Acquisition Engine',
    old:'Lead Generation',
    desc:'A systematic machine that qualifies, captures, and follows up every lead within minutes — while you are in a meeting, asleep, or on the field.',
  },
  {
    icon:'auto',
    title:'Operational Sovereignty',
    old:'Business Automation',
    desc:'Every hour your team spends on manual admin is revenue leakage. We eliminate the friction — invoices, reminders, scheduling — and give that time back to the work only you can do.',
  },
  {
    icon:'vis',
    title:'Market Dominance Signal',
    old:'Online Visibility',
    desc:'We engineer your digital presence so that when your ideal client searches, they find you first — and find a presence that makes competitors look amateur.',
  },
];

const previews = [
  {
    cat:'Logistics',
    title:'Tuma Logistics',
    desc:'A freight company drowning in WhatsApp chaos — no payment infrastructure, no lead system, no visibility.',
    result:'KES 840K automated in 90 days',
  },
  {
    cat:'Legal',
    title:'MSA Legal Partners',
    desc:'A top-tier law firm with a 2018 website that was actively eroding client trust.',
    result:'3.1× qualified enquiries in 60 days',
  },
];
---
<BaseLayout title="Authority Infrastructure for African Businesses" page="home">

<!-- ═══ HERO ═══ -->
<section style="position:relative;overflow:hidden;min-height:100svh;display:flex;flex-direction:column;justify-content:center;padding:clamp(80px,12vh,120px) clamp(20px,5vw,56px) clamp(60px,8vh,80px);">
  <canvas id="hero-canvas" aria-hidden="true" style="position:absolute;inset:0;width:100%;height:100%;pointer-events:none;z-index:0;"></canvas>

  <div id="hero-content" style="position:relative;z-index:2;max-width:780px;">

    <div class="pill rv" style="margin-bottom:clamp(20px,3vw,32px);width:fit-content;">
      <div class="dot"></div>
      <span style="font-family:var(--fm);font-size:clamp(.5rem,.7vw,.6rem);letter-spacing:.16em;text-transform:uppercase;color:var(--t3);">2 Client Slots Open · Mombasa & Nairobi</span>
    </div>

    <h1 class="rv" style="font-family:var(--fd);font-size:clamp(2.4rem,6vw,5.4rem);font-weight:300;line-height:1.04;letter-spacing:-.02em;color:var(--t1);margin-bottom:clamp(16px,2vw,24px);transition-delay:.08s;">
      Most African Businesses<br/>Don't Fail the Market.<br/>They Fail the <em style="color:var(--gold);font-style:italic;">Infrastructure.</em>
    </h1>

    <p class="rv" style="font-size:clamp(.9rem,1.4vw,1.08rem);font-weight:300;color:var(--t2);max-width:540px;line-height:1.76;margin-bottom:clamp(28px,4vw,44px);transition-delay:.18s;">
      We build the authority infrastructure — websites, liquidity automation, and client acquisition engines — that separate the businesses that scale from the ones that stay invisible.
    </p>

    <div class="hero-ctas rv" style="display:flex;gap:10px;flex-wrap:wrap;margin-bottom:clamp(36px,5vw,60px);transition-delay:.28s;">
      <a href="/assessment" class="btn-g">Diagnose Your Revenue Leakage →</a>
      <a href="/work" class="btn-o">See Infrastructure in Action</a>
    </div>

    <div class="rv" style="display:flex;gap:clamp(24px,4vw,48px);flex-wrap:wrap;transition-delay:.38s;">
      {[
        {v:'47',   l:'Systems Deployed'},
        {v:'KES 3.2M', l:'Revenue Automated'},
        {v:'2',    l:'Client Slots / Month'},
        {v:'100%', l:'On-Time Delivery'},
      ].map(p => (
        <div>
          <div style="font-family:var(--fd);font-size:clamp(1.6rem,3vw,2.4rem);font-weight:300;color:var(--gold);line-height:1;">{p.v}</div>
          <div style="font-family:var(--fm);font-size:clamp(.48rem,.65vw,.58rem);letter-spacing:.1em;color:var(--t3);text-transform:uppercase;margin-top:4px;">{p.l}</div>
        </div>
      ))}
    </div>

  </div>

  <div style="position:absolute;bottom:28px;left:50%;transform:translateX(-50%);z-index:2;display:flex;flex-direction:column;align-items:center;gap:6px;animation:float 2s ease-in-out infinite;" aria-hidden="true">
    <span style="font-family:var(--fm);font-size:.5rem;letter-spacing:.14em;color:var(--t3);text-transform:uppercase;">scroll</span>
    <svg width="16" height="20" viewBox="0 0 16 20" fill="none"><rect x="6" y="0" width="4" height="10" rx="2" fill="rgba(201,168,76,.5)"/><path d="M4 13l4 5 4-5" stroke="rgba(201,168,76,.5)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
  </div>
</section>


<!-- ═══ FOUNDER'S NOTE ═══ -->
<section class="sec" style="padding-top:0;padding-bottom:clamp(48px,7vw,72px);">
  <div class="rv" style="max-width:820px;margin:0 auto;">
    <div style="display:grid;grid-template-columns:auto 1fr;gap:clamp(24px,4vw,48px);align-items:start;" id="founders-grid">

      <!-- Avatar / Founder Signal -->
      <div style="display:flex;flex-direction:column;align-items:center;gap:12px;flex-shrink:0;">
        <div style="width:clamp(64px,9vw,88px);height:clamp(64px,9vw,88px);border-radius:50%;background:var(--g3);border:2px solid var(--gold);display:flex;align-items:center;justify-content:center;box-shadow:0 0 28px rgba(201,168,76,.2);">
          <span style="font-family:var(--fd);font-size:clamp(1.4rem,2.5vw,2rem);font-weight:300;color:var(--gold);">D</span>
        </div>
        <div style="display:flex;flex-direction:column;align-items:center;gap:4px;">
          <div style="font-family:var(--fm);font-size:.54rem;letter-spacing:.1em;color:var(--gold);text-transform:uppercase;">DR.DULLU</div>
          <div style="font-family:var(--fm);font-size:.5rem;color:var(--t3);text-align:center;">Founder, AXIS</div>
          <div style="display:flex;align-items:center;gap:5px;margin-top:2px;"><div class="dot" style="width:5px;height:5px;"></div><span style="font-family:var(--fm);font-size:.48rem;color:rgba(79,255,176,.7);">Available</span></div>
        </div>
      </div>

      <!-- The Note -->
      <div class="gc-dark" style="padding:clamp(20px,3.5vw,32px);position:relative;overflow:hidden;">
        <div style="position:absolute;top:0;left:0;right:0;height:2px;background:linear-gradient(90deg,var(--gold),transparent);"></div>
        <p class="lbl" style="margin-bottom:10px;">A Note from the Founder</p>
        <blockquote style="font-family:var(--fd);font-size:clamp(1.05rem,1.8vw,1.3rem);font-weight:300;color:var(--t1);line-height:1.7;font-style:italic;margin-bottom:16px;">
          "I spent months researching why most African startups fail — studying the pattern across hundreds of businesses from Lagos to Nairobi to Mombasa. The product is rarely the problem. The infrastructure always is. No system to collect payments reliably. No presence that commands authority. No machine that follows up a lead in minutes. I built AXIS to fix that. We don't build websites. We build the infrastructure that keeps your business from becoming a statistic."
        </blockquote>
        <div style="display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:12px;">
          <div>
            <div style="font-family:var(--fm);font-size:.62rem;color:var(--gold);letter-spacing:.06em;">DR.DULLU</div>
            <div style="font-family:var(--fm);font-size:.54rem;color:var(--t3);margin-top:2px;">Founder · Digital & Business Strategist · Researcher</div>
          </div>
          <div style="display:flex;gap:8px;flex-wrap:wrap;">
            <a href="https://substack.com" target="_blank" rel="noopener" class="btn-o" style="font-size:.64rem;padding:6px 12px;">Read the Research →</a>
            <a href="/assessment" class="btn-g" style="font-size:.64rem;padding:6px 12px;">Work With Me</a>
          </div>
        </div>
      </div>

    </div>
  </div>
</section>


<!-- ═══ SCARCITY / PRECISION SPRINT SIGNAL ═══ -->
<section style="padding:clamp(20px,3vw,28px) clamp(20px,5vw,56px);position:relative;z-index:1;">
  <div class="rv" style="max-width:820px;margin:0 auto;">
    <div style="background:rgba(201,168,76,.04);border:1px solid rgba(201,168,76,.2);border-radius:12px;padding:clamp(16px,3vw,24px);display:flex;align-items:center;gap:clamp(16px,3vw,28px);flex-wrap:wrap;">
      <div style="display:flex;align-items:center;gap:12px;flex-shrink:0;">
        <div style="width:44px;height:44px;border-radius:10px;background:var(--gd2);border:1px solid var(--gbh);display:flex;align-items:center;justify-content:center;">
          <svg width="20" height="20" viewBox="0 0 20 20" fill="none"><circle cx="10" cy="10" r="7" stroke="#C9A84C" stroke-width="1.2"/><path d="M10 6v4l2.5 2.5" stroke="#C9A84C" stroke-width="1.2" stroke-linecap="round"/></svg>
        </div>
        <div>
          <div style="font-family:var(--fm);font-size:.58rem;letter-spacing:.12em;text-transform:uppercase;color:var(--gold);">Precision Sprint Model</div>
          <div style="font-family:var(--fm);font-size:.52rem;color:var(--t3);margin-top:2px;">By design · Not by accident</div>
        </div>
      </div>
      <div style="flex:1;min-width:200px;">
        <p style="font-size:clamp(.8rem,1.1vw,.88rem);font-weight:300;color:var(--t2);line-height:1.68;">
          Because I operate with surgical precision around my research and academic commitments, <strong style="color:var(--t1);font-weight:500;">I take a maximum of 2 clients per month.</strong> This ensures your infrastructure receives 100% of my sovereign focus — not divided attention. If you're serious about your business, apply now.
        </p>
      </div>
      <a href="/assessment" class="btn-g" style="flex-shrink:0;font-size:.74rem;">Check Availability →</a>
    </div>
  </div>
</section>


<!-- ═══ SERVICES — UPGRADED VOCABULARY ═══ -->
<section class="sec" style="background:rgba(14,34,20,.5);">
  <p class="lbl rv" style="margin-bottom:8px;">The Infrastructure Stack</p>
  <h2 class="sh rv" style="margin-bottom:8px;transition-delay:.08s;">Five Systems.<br/><em style="color:var(--gold);font-style:italic;">One Sovereign Operation.</em></h2>
  <p class="body-t rv" style="margin-bottom:clamp(24px,4vw,40px);max-width:500px;transition-delay:.16s;">Every engagement is a system — not a deliverable. Each component is engineered to compound the others.</p>

  <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(min(260px,100%),1fr));gap:clamp(10px,1.5vw,14px);">
    {services.map((s, i) => (
      <div class="gc rv svc-card" style={`padding:clamp(20px,3vw,28px);position:relative;overflow:hidden;transition-delay:${i*.06}s;`}>
        <div style="position:absolute;top:0;left:0;right:0;height:2px;background:linear-gradient(90deg,transparent,var(--gold),transparent);opacity:0;transition:opacity .3s;" class="svc-line"></div>
        <div style="width:40px;height:40px;border-radius:9px;background:var(--gd2);border:1px solid var(--gbh);display:flex;align-items:center;justify-content:center;margin-bottom:16px;">
          {s.icon==='grid'&&<svg width="18" height="18" viewBox="0 0 18 18" fill="none"><rect x="2" y="2" width="6" height="6" rx="1.5" stroke="#C9A84C" stroke-width="1.1"/><rect x="10" y="2" width="6" height="6" rx="1.5" stroke="#C9A84C" stroke-width="1.1"/><rect x="2" y="10" width="6" height="6" rx="1.5" stroke="#C9A84C" stroke-width="1.1"/><rect x="10" y="10" width="6" height="6" rx="1.5" stroke="#C9A84C" stroke-width="1.1" opacity=".4"/></svg>}
          {s.icon==='pay'&&<svg width="18" height="18" viewBox="0 0 18 18" fill="none"><circle cx="9" cy="9" r="6" stroke="#C9A84C" stroke-width="1.1"/><path d="M6 9h6M9 6v6" stroke="#C9A84C" stroke-width="1.1" stroke-linecap="round"/></svg>}
          {s.icon==='grow'&&<svg width="18" height="18" viewBox="0 0 18 18" fill="none"><path d="M3 13l4-4 3 3 5-5" stroke="#C9A84C" stroke-width="1.1" stroke-linecap="round" stroke-linejoin="round"/></svg>}
          {s.icon==='auto'&&<svg width="18" height="18" viewBox="0 0 18 18" fill="none"><path d="M9 2v4M9 12v4M2 9h4M12 9h4" stroke="#C9A84C" stroke-width="1.1" stroke-linecap="round"/><circle cx="9" cy="9" r="3" stroke="#C9A84C" stroke-width="1.1"/></svg>}
          {s.icon==='vis'&&<svg width="18" height="18" viewBox="0 0 18 18" fill="none"><circle cx="9" cy="6" r="3" stroke="#C9A84C" stroke-width="1.1"/><path d="M3 16c0-3.314 2.686-5 6-5s6 1.686 6 5" stroke="#C9A84C" stroke-width="1.1" stroke-linecap="round"/></svg>}
        </div>
        <div style="margin-bottom:4px;">
          <h3 style="font-family:var(--fd);font-size:clamp(1.1rem,1.5vw,1.2rem);font-weight:400;color:var(--t1);">{s.title}</h3>
          <span style="font-family:var(--fm);font-size:.5rem;color:var(--t3);letter-spacing:.06em;">formerly "{s.old}"</span>
        </div>
        <p style="font-size:clamp(.78rem,1vw,.82rem);font-weight:300;color:var(--t3);line-height:1.64;margin-top:8px;">{s.desc}</p>
      </div>
    ))}

    <!-- Diagnostic CTA card -->
    <div class="gc rv" style="padding:clamp(20px,3vw,28px);background:var(--gd2);border-color:var(--gbh);">
      <p class="lbl" style="margin-bottom:8px;">Not sure where your leakage is?</p>
      <h3 style="font-family:var(--fd);font-size:clamp(1.1rem,1.5vw,1.3rem);font-weight:300;color:var(--t1);margin-bottom:8px;">Run a free<br/>Infrastructure Diagnostic</h3>
      <p style="font-size:clamp(.76rem,1vw,.82rem);font-weight:300;color:var(--t3);line-height:1.64;margin-bottom:16px;">3 targeted questions. We identify exactly where your business is haemorrhaging revenue and show you the fix.</p>
      <a href="/assessment" class="btn-g" style="width:100%;justify-content:center;font-size:.72rem;">Run Diagnostic →</a>
    </div>
  </div>
</section>


<!-- ═══ WHY AXIS ═══ -->
<section class="sec">
  <div id="why-grid" style="display:grid;grid-template-columns:1fr 1fr;gap:clamp(28px,5vw,56px);align-items:center;">
    <div>
      <p class="lbl rv" style="margin-bottom:8px;">The Research Behind the Build</p>
      <h2 class="sh rv" style="margin-bottom:16px;transition-delay:.08s;">Infrastructure Failure<br/><em style="color:var(--gold);font-style:italic;">Is the African Startup Crisis</em></h2>
      <p class="body-t rv" style="margin-bottom:12px;transition-delay:.16s;">After months studying why East African businesses stagnate — consulting firms, logistics companies, property agencies, agritech platforms — the pattern is consistent: it is never the product. It is the absence of a system to collect money reliably, follow up leads automatically, and project authority to the market.</p>
      <p class="body-t rv" style="margin-bottom:24px;transition-delay:.24s;">AXIS exists because that research demanded a builder. Every system we deploy is designed using the same frameworks published in the DR.DULLU research series.</p>
      <div style="display:flex;gap:10px;flex-wrap:wrap;" class="rv" style="transition-delay:.32s;">
        <a href="/work" class="btn-o">See the Results →</a>
        <a href="https://substack.com" target="_blank" rel="noopener" class="btn-o">Read the Research</a>
      </div>
    </div>
    <div class="rv" style="position:relative;height:clamp(240px,35vw,340px);transition-delay:.12s;">
      <canvas id="fib-sm" style="width:100%;height:100%;"></canvas>
    </div>
  </div>
</section>


<!-- ═══ WORK PREVIEW ═══ -->
<section class="sec" style="padding-top:0;">
  <div style="display:flex;justify-content:space-between;align-items:flex-end;flex-wrap:wrap;gap:12px;margin-bottom:clamp(20px,3vw,32px);">
    <div>
      <p class="lbl rv" style="margin-bottom:6px;">Infrastructure in the Wild</p>
      <h2 class="sh rv" style="transition-delay:.08s;">Businesses That Stopped<br/><em style="color:var(--gold);font-style:italic;">Leaking Revenue</em></h2>
    </div>
    <a href="/work" class="btn-o rv">Full Case Studies →</a>
  </div>
  <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(min(300px,100%),1fr));gap:14px;">
    {previews.map((p, i) => (
      <a href="/work" style="text-decoration:none;">
        <div class="gc rv" style={`padding:clamp(18px,3vw,26px);transition-delay:${i*.08}s;`}>
          <div style="display:flex;align-items:center;gap:8px;margin-bottom:12px;flex-wrap:wrap;">
            <span class="cat-tag">{p.cat}</span>
            <div style="display:flex;align-items:center;gap:5px;margin-left:auto;"><div class="dot"></div><span style="font-family:var(--fm);font-size:.54rem;color:rgba(79,255,176,.65);">Live</span></div>
          </div>
          <h3 style="font-family:var(--fd);font-size:clamp(1.3rem,2vw,1.5rem);font-weight:300;color:var(--t1);margin-bottom:6px;">{p.title}</h3>
          <p style="font-size:clamp(.78rem,1vw,.82rem);font-weight:300;color:var(--t3);line-height:1.62;margin-bottom:12px;">{p.desc}</p>
          <div class="rb"><div class="rl">Measured Result</div><div class="rval">{p.result}</div></div>
        </div>
      </a>
    ))}
  </div>
</section>


<!-- ═══ LEAD CAPTURE — STARTUP FAILURE REPORT ═══ -->
<section class="sec" style="padding-top:0;">
  <div class="rv" id="report-section">
    <div style="background:linear-gradient(135deg,rgba(26,61,34,.9),rgba(12,28,18,.95));border:1px solid rgba(201,168,76,.25);border-radius:16px;padding:clamp(28px,5vw,48px);position:relative;overflow:hidden;">
      <div style="position:absolute;top:0;left:0;right:0;height:2px;background:linear-gradient(90deg,transparent,var(--gold),transparent);"></div>
      <div style="position:absolute;top:-20px;right:-20px;width:180px;height:180px;border-radius:50%;background:rgba(201,168,76,.04);pointer-events:none;"></div>

      <div style="display:grid;grid-template-columns:1fr auto;gap:clamp(24px,4vw,48px);align-items:center;flex-wrap:wrap;" id="report-grid">
        <div>
          <div style="display:inline-flex;align-items:center;gap:8px;padding:5px 12px;background:rgba(201,168,76,.1);border:1px solid rgba(201,168,76,.2);border-radius:20px;margin-bottom:14px;">
            <svg width="12" height="12" viewBox="0 0 12 12" fill="none"><path d="M6 1L7.5 4.5H11L8.25 6.75 9.5 10.5 6 8.25 2.5 10.5 3.75 6.75 1 4.5H4.5L6 1Z" fill="#C9A84C"/></svg>
            <span style="font-family:var(--fm);font-size:.52rem;letter-spacing:.1em;color:var(--gold);text-transform:uppercase;">Free Research Report</span>
          </div>
          <h2 style="font-family:var(--fd);font-size:clamp(1.6rem,3vw,2.4rem);font-weight:300;color:var(--t1);line-height:1.15;margin-bottom:12px;">
            Why 73% of East African<br/><em style="color:var(--gold);font-style:italic;">Startups Fail in Year Two</em>
          </h2>
          <p style="font-size:clamp(.84rem,1.1vw,.92rem);font-weight:300;color:var(--t2);line-height:1.72;max-width:480px;margin-bottom:6px;">The infrastructure failure patterns your competitors don't want you to understand. Based on months of primary research across Kenyan, Ugandan, and Nigerian SMEs.</p>
          <p style="font-family:var(--fm);font-size:.58rem;color:var(--t3);margin-bottom:20px;">Covers: payment infrastructure failure · authority vacuum · lead leakage · operational drag</p>

          <!-- Capture form -->
          <div id="report-form" style="display:flex;gap:8px;flex-wrap:wrap;max-width:460px;">
            <input id="report-email" type="email" placeholder="your@email.com" class="inp" style="flex:1;min-width:200px;margin-bottom:0;font-size:.86rem;"/>
            <button onclick="claimReport()" class="btn-g" style="flex-shrink:0;font-size:.8rem;padding:12px 20px;">Get Free Report →</button>
          </div>
          <div id="report-success" style="display:none;padding:12px 16px;background:rgba(79,255,176,.08);border:1px solid rgba(79,255,176,.2);border-radius:8px;max-width:460px;">
            <p style="font-family:var(--fm);font-size:.68rem;color:var(--sig);">✓ Report incoming. Check your inbox — it'll be there in minutes.</p>
          </div>
          <p style="font-family:var(--fm);font-size:.52rem;color:var(--t3);margin-top:8px;">No spam. Unsubscribe anytime. Your email powers your playbook notification when it launches.</p>
        </div>

        <!-- Report mockup -->
        <div class="hide-mob" style="flex-shrink:0;">
          <div style="width:clamp(100px,14vw,150px);aspect-ratio:3/4;background:var(--g2);border:1px solid var(--gbh);border-radius:10px;position:relative;overflow:hidden;box-shadow:8px 8px 24px rgba(0,0,0,.5),-2px -2px 8px rgba(201,168,76,.1);">
            <div style="height:6px;background:var(--gold);"></div>
            <div style="padding:12px;">
              <div style="font-family:var(--fm);font-size:.42rem;color:var(--gold);margin-bottom:4px;text-transform:uppercase;letter-spacing:.08em;">DR.DULLU</div>
              <div style="font-family:var(--fd);font-size:.72rem;color:var(--t1);line-height:1.2;margin-bottom:8px;">Why African Startups Fail</div>
              <div style="height:1px;background:rgba(255,255,255,.1);margin-bottom:8px;"></div>
              {Array(7).fill(0).map((_,i)=>(
                <div style={`height:3px;border-radius:1px;background:rgba(255,255,255,${0.06+i*.02});margin-bottom:4px;width:${90-i*8}%;`}></div>
              ))}
            </div>
            <div style="position:absolute;bottom:10px;right:10px;width:24px;height:24px;border-radius:50%;background:var(--gd2);border:1px solid var(--gbh);display:flex;align-items:center;justify-content:center;">
              <span style="font-family:var(--fd);font-size:.55rem;color:var(--gold);">D</span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>


<!-- ═══ CLOSING CTA ═══ -->
<section class="sec" style="padding-top:0;">
  <div class="gc-dark rv" style="padding:clamp(32px,5vw,52px);text-align:center;">
    <p class="lbl" style="margin-bottom:10px;">2 Slots. This Month.</p>
    <h2 class="sh" style="margin-bottom:12px;">Your Infrastructure<br/><em style="color:var(--gold);font-style:italic;">Audit Is Free</em></h2>
