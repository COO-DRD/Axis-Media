---
import BaseLayout from '../layouts/BaseLayout.astro';
const services = [
  {icon:'grid',title:'Professional Website',desc:'A fast, mobile-first website that looks the part and turns visitors into paying clients. Built for the Kenyan market.'},
  {icon:'pay', title:'M-Pesa Payments',     desc:'Accept payments on your website via M-Pesa. Instant notifications, automated receipts, a clean experience clients trust.'},
  {icon:'grow',title:'Client Acquisition',  desc:'Systems that bring in enquiries while you work. Automated follow-ups and booking flows — no lead slips through.'},
  {icon:'auto',title:'Business Automation', desc:'Replace repetitive admin with systems that run themselves — invoices, reminders, scheduling.'},
  {icon:'vis', title:'Online Visibility',   desc:'Show up when your ideal clients search for what you offer. We build your Google presence so the right people find you.'},
];
const previews = [
  {cat:'Logistics',title:'Tuma Logistics',    desc:'A freight company drowning in WhatsApp messages — no payment system, no lead tracking.',  result:'KES 840K automated in 90 days'},
  {cat:'Legal',    title:'MSA Legal Partners',desc:'A respected law firm with a 2018 website actively costing them clients.',                   result:'3.1× more qualified enquiries'},
];
---
<BaseLayout title="Digital Systems That Earn" page="home">

<section style="position:relative;overflow:hidden;min-height:100svh;display:flex;flex-direction:column;justify-content:center;padding:clamp(80px,12vh,120px) clamp(20px,5vw,56px) clamp(60px,8vh,80px);">
  <canvas id="hero-canvas" aria-hidden="true" style="position:absolute;inset:0;width:100%;height:100%;pointer-events:none;z-index:0;"></canvas>
  <div id="hero-content" style="position:relative;z-index:2;">
    <div class="pill rv" style="margin-bottom:clamp(20px,3vw,32px);width:fit-content;">
      <div class="dot"></div>
      <span style="font-family:var(--fm);font-size:clamp(.5rem,.7vw,.6rem);letter-spacing:.16em;text-transform:uppercase;color:var(--t3);">Mombasa · Nairobi · Kenya</span>
    </div>
    <h1 class="rv" style="font-family:var(--fd);font-size:clamp(2.4rem,6vw,5.2rem);font-weight:300;line-height:1.04;letter-spacing:-.02em;color:var(--t1);max-width:700px;margin-bottom:clamp(16px,2vw,24px);transition-delay:.08s;">
      Your Business<br/>Deserves a Presence<br/>That <em style="color:var(--gold);font-style:italic;">Earns.</em>
    </h1>
    <p class="rv" style="font-size:clamp(.9rem,1.4vw,1.05rem);font-weight:300;color:var(--t2);max-width:500px;line-height:1.74;margin-bottom:clamp(28px,4vw,44px);transition-delay:.18s;">
      We build the websites, M-Pesa payment systems, and automation tools that turn your expertise into consistent revenue — so you focus on the work only you can do.
    </p>
    <div class="hero-ctas rv" style="display:flex;gap:10px;flex-wrap:wrap;margin-bottom:clamp(40px,6vw,72px);transition-delay:.28s;">
      <a href="/assessment" class="btn-g">Get Free Assessment →</a>
      <a href="/work"       class="btn-o">See Our Work</a>
    </div>
    <div class="rv" style="display:flex;gap:clamp(24px,4vw,48px);flex-wrap:wrap;transition-delay:.38s;">
      {[{v:'47',l:'Projects Delivered'},{v:'KES 3.2M',l:'Payments Automated'},{v:'100%',l:'On-Time Delivery'},{v:'98ms',l:'Avg. Load Speed'}].map(p=>(
        <div>
          <div style="font-family:var(--fd);font-size:clamp(1.6rem,3vw,2.4rem);font-weight:300;color:var(--gold);line-height:1;">{p.v}</div>
          <div style="font-family:var(--fm);font-size:clamp(.48rem,.65vw,.58rem);letter-spacing:.1em;color:var(--t3);text-transform:uppercase;margin-top:4px;">{p.l}</div>
        </div>
      ))}
    </div>
  </div>
  <div style="position:absolute;bottom:28px;left:50%;transform:translateX(-50%);z-index:2;display:flex;flex-direction:column;align-items:center;gap:6px;animation:float 2s ease-in-out infinite;" aria-hidden="true">
    <span style="font-family:var(--fm);font-size:.5rem;letter-spacing:.14em;color:var(--t3);text-transform:uppercase;">scroll</span>
    <svg width="16" height="20" viewBox="0 0 16 20" fill="none"><rect x="6" y="0" width="4" height="10" rx="2" fill="rgba(201,168,76,.5)"/><path d="M4 13l4 5 4-5" stroke="rgba(201,168,76,.5)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
  </div>
</section>

<section class="sec" style="background:rgba(14,34,20,.5);">
  <p class="lbl rv" style="margin-bottom:8px;">What We Do</p>
  <h2 class="sh rv" style="margin-bottom:8px;transition-delay:.08s;">Everything Your Business<br/><em style="color:var(--gold);font-style:italic;">Needs Online</em></h2>
  <p class="body-t rv" style="margin-bottom:clamp(24px,4vw,40px);max-width:480px;transition-delay:.16s;">From your first website to a fully automated operation — we build it, launch it, and keep it running.</p>
  <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(min(260px,100%),1fr));gap:clamp(10px,1.5vw,14px);">
    {services.map((s,i)=>(
      <div class="gc rv svc-card" style={`padding:clamp(20px,3vw,28px);position:relative;overflow:hidden;transition-delay:${i*.06}s;`}>
        <div style="position:absolute;top:0;left:0;right:0;height:2px;background:linear-gradient(90deg,transparent,var(--gold),transparent);opacity:0;transition:opacity .3s;" class="svc-line"></div>
        <div style="width:40px;height:40px;border-radius:9px;background:var(--gd2);border:1px solid var(--gbh);display:flex;align-items:center;justify-content:center;margin-bottom:16px;">
          {s.icon==='grid'&&<svg width="18" height="18" viewBox="0 0 18 18" fill="none"><rect x="2" y="2" width="6" height="6" rx="1.5" stroke="#C9A84C" stroke-width="1.1"/><rect x="10" y="2" width="6" height="6" rx="1.5" stroke="#C9A84C" stroke-width="1.1"/><rect x="2" y="10" width="6" height="6" rx="1.5" stroke="#C9A84C" stroke-width="1.1"/><rect x="10" y="10" width="6" height="6" rx="1.5" stroke="#C9A84C" stroke-width="1.1" opacity=".4"/></svg>}
          {s.icon==='pay'&&<svg width="18" height="18" viewBox="0 0 18 18" fill="none"><circle cx="9" cy="9" r="6" stroke="#C9A84C" stroke-width="1.1"/><path d="M6 9h6M9 6v6" stroke="#C9A84C" stroke-width="1.1" stroke-linecap="round"/></svg>}
          {s.icon==='grow'&&<svg width="18" height="18" viewBox="0 0 18 18" fill="none"><path d="M3 13l4-4 3 3 5-5" stroke="#C9A84C" stroke-width="1.1" stroke-linecap="round" stroke-linejoin="round"/></svg>}
          {s.icon==='auto'&&<svg width="18" height="18" viewBox="0 0 18 18" fill="none"><path d="M9 2v4M9 12v4M2 9h4M12 9h4" stroke="#C9A84C" stroke-width="1.1" stroke-linecap="round"/><circle cx="9" cy="9" r="3" stroke="#C9A84C" stroke-width="1.1"/></svg>}
          {s.icon==='vis'&&<svg width="18" height="18" viewBox="0 0 18 18" fill="none"><circle cx="9" cy="6" r="3" stroke="#C9A84C" stroke-width="1.1"/><path d="M3 16c0-3.314 2.686-5 6-5s6 1.686 6 5" stroke="#C9A84C" stroke-width="1.1" stroke-linecap="round"/></svg>}
        </div>
        <h3 style="font-family:var(--fd);font-size:clamp(1.1rem,1.5vw,1.2rem);font-weight:400;color:var(--t1);margin-bottom:6px;">{s.title}</h3>
        <p style="font-size:clamp(.78rem,1vw,.82rem);font-weight:300;color:var(--t3);line-height:1.64;">{s.desc}</p>
      </div>
    ))}
    <div class="gc rv" style="padding:clamp(20px,3vw,28px);background:var(--gd2);border-color:var(--gbh);">
      <p class="lbl" style="margin-bottom:8px;">Not sure where to start?</p>
      <h3 style="font-family:var(--fd);font-size:clamp(1.1rem,1.5vw,1.3rem);font-weight:300;color:var(--t1);margin-bottom:8px;">Get a free<br/>business review</h3>
      <p style="font-size:clamp(.76rem,1vw,.82rem);font-weight:300;color:var(--t3);line-height:1.64;margin-bottom:16px;">We look at your situation and tell you what will make the biggest difference. Free. No obligation.</p>
      <a href="/assessment" class="btn-g" style="width:100%;justify-content:center;font-size:.72rem;">Book Assessment →</a>
    </div>
  </div>
</section>

<section class="sec">
  <div id="why-grid" style="display:grid;grid-template-columns:1fr 1fr;gap:clamp(28px,5vw,56px);align-items:center;">
    <div>
      <p class="lbl rv" style="margin-bottom:8px;">Why AXIS</p>
      <h2 class="sh rv" style="margin-bottom:16px;transition-delay:.08s;">We Build Systems,<br/><em style="color:var(--gold);font-style:italic;">Not Just Websites</em></h2>
      <p class="body-t rv" style="margin-bottom:12px;transition-delay:.16s;">Most agencies hand you a website and disappear. We build everything together — your website, payments, communications, and visibility — so each part makes the others stronger.</p>
      <p class="body-t rv" style="margin-bottom:24px;transition-delay:.24s;">Like the Fibonacci sequence, every part of your digital system compounds. Each client brings better clients. The system grows with you.</p>
      <a href="/work" class="btn-o rv" style="transition-delay:.32s;">See Results →</a>
    </div>
    <div class="rv" style="position:relative;height:clamp(240px,35vw,340px);transition-delay:.12s;">
      <canvas id="fib-sm" style="width:100%;height:100%;"></canvas>
    </div>
  </div>
</section>

<section class="sec" style="padding-top:0;">
  <div style="display:flex;justify-content:space-between;align-items:flex-end;flex-wrap:wrap;gap:12px;margin-bottom:clamp(20px,3vw,32px);">
    <div>
      <p class="lbl rv" style="margin-bottom:6px;">Recent Work</p>
      <h2 class="sh rv" style="transition-delay:.08s;">Businesses We've<br/><em style="color:var(--gold);font-style:italic;">Transformed</em></h2>
    </div>
    <a href="/work" class="btn-o rv">View All Work →</a>
  </div>
  <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(min(300px,100%),1fr));gap:14px;">
    {previews.map((p,i)=>(
      <a href="/work" style="text-decoration:none;">
        <div class="gc rv" style={`padding:clamp(18px,3vw,26px);transition-delay:${i*.08}s;`}>
          <div style="display:flex;align-items:center;gap:8px;margin-bottom:12px;flex-wrap:wrap;">
            <span class="cat-tag">{p.cat}</span>
            <div style="display:flex;align-items:center;gap:5px;margin-left:auto;"><div class="dot"></div><span style="font-family:var(--fm);font-size:.54rem;color:rgba(79,255,176,.65);">Live</span></div>
          </div>
          <h3 style="font-family:var(--fd);font-size:clamp(1.3rem,2vw,1.5rem);font-weight:300;color:var(--t1);margin-bottom:6px;">{p.title}</h3>
          <p style="font-size:clamp(.78rem,1vw,.82rem);font-weight:300;color:var(--t3);line-height:1.62;margin-bottom:12px;">{p.desc}</p>
          <div class="rb"><div class="rl">Result</div><div class="rval">{p.result}</div></div>
        </div>
      </a>
    ))}
  </div>
</section>

<section class="sec" style="padding-top:0;">
  <div class="gc-dark rv" style="padding:clamp(32px,5vw,52px);text-align:center;">
    <p class="lbl" style="margin-bottom:10px;">Ready to Start?</p>
    <h2 class="sh" style="margin-bottom:12px;">Let's Talk About<br/><em style="color:var(--gold);font-style:italic;">Your Business</em></h2>
    <p class="body-t" style="max-width:440px;margin:0 auto clamp(24px,4vw,36px);">Tell us where you are and where you want to go. We'll come back with a clear plan and a price that makes sense.</p>
    <div style="display:flex;gap:10px;justify-content:center;flex-wrap:wrap;">
      <a href="/assessment" class="btn-g" style="font-size:.86rem;padding:12px 26px;">Start Free Assessment →</a>
      <a href="/work"       class="btn-o" style="font-size:.86rem;padding:12px 26px;">See Our Work</a>
    </div>
  </div>
</section>

</BaseLayout>

<style>
  @keyframes float{0%,100%{transform:translateX(-50%) translateY(0);}50%{transform:translateX(-50%) translateY(-6px);}}
  .svc-card:hover .svc-line{opacity:1 !important;}
  @media(max-width:640px){#why-grid{grid-template-columns:1fr !important;}}
</style>

<script is:inline>
// Hero canvas
(function(){
  var c=document.getElementById('hero-canvas');if(!c)return;
  var PHI=1.618;
  function draw(){
    var w=c.offsetWidth,h=c.offsetHeight;c.width=w;c.height=h;
    var x=c.getContext('2d');
    x.strokeStyle='rgba(201,168,76,.09)';x.lineWidth=1;
    var rw=Math.min(w,h)*.5,rh=rw/PHI,rx=w*.1,ry=h*.15;
    for(var i=0;i<6;i++){x.strokeRect(rx,ry,rw,rh);rh=rw/PHI;rw=rh;rx+=rw*.04;ry+=rh*.04;}
    x.strokeStyle='rgba(201,168,76,.1)';x.lineWidth=1.2;
    x.beginPath();
    var cx=w*.76,cy=h*.5;
    for(var a=0;a<Math.PI*6;a+=.04){
      var r=3*Math.pow(PHI,a/Math.PI/2);
      var px=cx+r*Math.cos(a),py=cy+r*Math.sin(a);
      a===0?x.moveTo(px,py):x.lineTo(px,py);
      if(r>Math.max(w,h))break;
    }
    x.stroke();
    x.fillStyle='rgba(201,168,76,.22)';
    [1,1,2,3,5,8,13,21,34].forEach(function(f,i){
      var a=i*Math.PI/PHI;
      x.beginPath();x.arc(w/2+f*Math.cos(a)*5,h/2+f*Math.sin(a)*3.5,Math.min(f*.18+.5,3),0,Math.PI*2);x.fill();
    });
  }
  window.addEventListener('resize',draw,{passive:true});
  setTimeout(draw,50);
})();

// Fib small canvas
(function(){
  var c=document.getElementById('fib-sm');if(!c)return;
  function draw(){
    var w=c.offsetWidth,h=c.offsetHeight;
    c.width=w*2;c.height=h*2;
    var x=c.getContext('2d');x.scale(2,2);
    var u=Math.min(w,h)/50,cx=w/2,cy=h/2;
    [[cx,cy-u,u],[cx-u,cy-u,u],[cx-u,cy-2*u,u*2],[cx,cy-u*4,u*3],[cx-u*5,cy-u*5,u*5],[cx-u*5,cy+u*3,u*8]].forEach(function(r,i){
      x.strokeStyle=i%2?'rgba(45,107,63,.35)':'rgba(201,168,76,.22)';x.lineWidth=.7;
      x.strokeRect(r[0],r[1],r[2],r[2]);
    });
    x.strokeStyle='rgba(201,168,76,.55)';x.lineWidth=1.1;
    [[cx+u,cy,u,Math.PI,1.5*Math.PI],[cx-u,cy-u,u,0,.5*Math.PI],[cx-u,cy+u,u*2,1.5*Math.PI,2*Math.PI],[cx+u*3,cy-u,u*3,.5*Math.PI,Math.PI],[cx+u*3,cy+u*7,u*5,Math.PI,1.5*Math.PI]].forEach(function(a){
      x.beginPath();x.arc(a[0],a[1],a[2],a[3],a[4]);x.stroke();
    });
    x.fillStyle='rgba(201,168,76,.38)';
    x.font=(u*.7)+'px JetBrains Mono,monospace';x.textAlign='center';
    x.fillText('φ = 1.618…',cx+u*8,cy-u*8);
  }
  window.addEventListener('resize',function(){setTimeout(draw,80);},{passive:true});
  setTimeout(draw,80);
})();
</script>
