---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Page Not Found"
  description="The page you are looking for does not exist. Begin the AXIS Infrastructure Audit."
>
  <section style="min-height:80vh;display:flex;align-items:center;justify-content:center;padding:80px 0;">
    <div class="section-container" style="text-align:center;">
      <div class="glass-card" style="max-width:560px;margin:0 auto;padding:64px 48px;">
        <p style="font-family:var(--font-display);font-size:6rem;font-weight:300;color:rgba(201,168,76,0.15);line-height:1;margin-bottom:16px;">404</p>
        <p class="t-label" style="margin-bottom:12px;">DEAD LINK INTERCEPTED</p>
        <h1 style="font-family:var(--font-display);font-size:2rem;font-weight:400;color:rgba(255,255,255,0.95);margin-bottom:16px;">
          This Page Does Not Exist.
        </h1>
        <p class="t-body" style="margin-bottom:36px;">
          The link you followed leads nowhere. The AXIS infrastructure has no dead ends — only redirections toward utility.
        </p>
        <div style="display:flex;gap:12px;justify-content:center;flex-wrap:wrap;">
          <a href="/?ref=404" class="btn-primary">Begin Infrastructure Audit</a>
          <a href="/archive"  class="btn-ghost">Review Systems Archive</a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
