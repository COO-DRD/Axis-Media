---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout title="Page Not Found">
  <section style="min-height:80vh;display:flex;align-items:center;justify-content:center;padding:80px 28px;position:relative;z-index:1;">
    <div class="glass" style="max-width:520px;width:100%;margin:0 auto;padding:56px 44px;text-align:center;border-radius:18px;">
      <p style="font-family:var(--font-display);font-size:5rem;font-weight:300;color:rgba(201,168,76,0.15);line-height:1;margin-bottom:12px;">404</p>
      <p class="t-label" style="margin-bottom:10px;">Page Not Found</p>
      <h1 style="font-family:var(--font-display);font-size:1.8rem;font-weight:300;color:var(--t1);margin-bottom:14px;">This page doesn't exist.</h1>
      <p class="t-body" style="margin-bottom:32px;">Let us point you somewhere useful instead.</p>
      <div style="display:flex;gap:10px;justify-content:center;flex-wrap:wrap;">
        <a href="/?ref=404" class="btn-gold">Go Home</a>
        <a href="/work" class="btn-outline">See Our Work</a>
      </div>
    </div>
  </section>
</BaseLayout>
