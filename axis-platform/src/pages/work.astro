---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout title="Our Work" description="Live digital systems built by AXIS for Kenyan businesses. Full case studies with problem, solution, cost, timeline, and client feedback." page="work">

<div id="img-modal" style="display:none;position:fixed;inset:0;background:rgba(0,0,0,.93);z-index:900;align-items:center;justify-content:center;padding:20px;" onclick="if(event.target===this)closeModal()">
  <div style="max-width:900px;width:100%;position:relative;">
    <button onclick="closeModal()" style="position:absolute;top:-36px;right:0;background:transparent;border:none;color:rgba(255,255,255,.6);font-size:1.1rem;cursor:pointer;font-family:var(--fm);">✕ close</button>
    <canvas id="modal-c" width="900" height="506" style="width:100%;border-radius:12px;border:1px solid var(--gb);display:block;"></canvas>
    <p id="modal-lbl" style="font-family:var(--fm);font-size:.56rem;color:rgba(255,255,255,.4);text-align:center;margin-top:8px;letter-spacing:.08em;"></p>
  </div>
</div>

<div id="pg-list">
  <section class="sec" style="padding-top:clamp(56px,10vw,80px);">
    <p class="lbl rv" style="margin-bottom:8px;">Our Work</p>
    <h1 class="sh rv" style="font-size:clamp(2rem,4.5vw,3.4rem);margin-bottom:12px;transition-delay:.08s;">Results That<br/><em style="color:var(--gold);font-style:italic;">Speak for Themselves</em></h1>
    <p class="body-t rv" style="max-width:520px;margin-bottom:clamp(28px,4vw,40px);transition-delay:.16s;">Every project below is live. Click any card to read the full story — the problem, solution, timeline, cost, and what the client said.</p>
    <div id="trust-g" style="display:grid;grid-template-columns:repeat(4,1fr);gap:10px;margin-bottom:clamp(32px,5vw,48px);">
      {[{n:'47',l:'Projects'},{n:'3.2M',l:'KES Automated'},{n:'100%',l:'Uptime'},{n:'4.9',l:'Avg. Rating'}].map((t,i)=>(
        <div class="gc rv" style={`padding:clamp(14px,2.5vw,20px);text-align:center;transition-delay:${i*.06}s;`}>
          <div style="font-family:var(--fd);font-size:clamp(1.5rem,3vw,2rem);font-weight:300;color:var(--gold);">{t.n}</div>
          <div class="lbl" style="font-size:.5rem;margin-top:4px;">{t.l}</div>
        </div>
      ))}
    </div>
    <div id="cards-wrap"></div>
  </section>
</div>

<div id="pg-detail" style="display:none;">
  <section class="sec" style="padding-top:clamp(40px,7vw,64px);padding-bottom:0;border-bottom:1px solid var(--gb);position:relative;">
    <div style="position:absolute;top:0;left:0;right:0;height:2px;background:linear-gradient(90deg,transparent,var(--gold),transparent);"></div>
    <button onclick="goList()" style="display:flex;align-items:center;gap:8px;font-family:var(--fm);font-size:.6rem;letter-spacing:.1em;text-transform:uppercase;color:var(--t3);cursor:pointer;border:none;background:transparent;margin-bottom:16px;padding:0;transition:color .18s;" onmouseover="this.style.color='var(--gold)'" onmouseout="this.style.color='var(--t3)'">
      <svg width="14" height="14" viewBox="0 0 14 14" fill="none"><path d="M9 2L4 7l5 5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
      Back to All Work
    </button>
    <div id="d-meta" style="display:flex;align-items:center;gap:10px;margin-bottom:12px;flex-wrap:wrap;"></div>
    <h1 id="d-title" style="font-family:var(--fd);font-size:clamp(2rem,4.5vw,3.6rem);font-weight:300;color:var(--t1);margin-bottom:10px;"></h1>
    <p id="d-tagline" style="font-size:clamp(.9rem,1.3vw,1.05rem);font-weight:300;color:var(--t2);max-width:600px;line-height:1.7;"></p>
  </section>
  <div id="detail-grid" style="display:grid;grid-template-columns:1fr clamp(200px,25vw,300px);gap:clamp(24px,4vw,48px);padding:clamp(28px,5vw,56px) clamp(20px,5vw,48px);">
    <div id="d-main"></div>
    <div id="d-sidebar"></div>
  </div>
</div>

</BaseLayout>

<script is:inline>
var PROJECTS=[
  {id:'tuma',cat:'Logistics',year:'2024',title:'Tuma Logistics',
   tagline:'How a freight company went from WhatsApp chaos to KES 840K in automated payments — in 90 days.',
   problem:'Tuma Logistics was booking freight jobs entirely over WhatsApp. There was no record system, no way to accept payment online, and no way to follow up on the 30% of enquiries that went cold every month. The founders were spending 4+ hours daily on admin that should have taken minutes.',
   solution:'We built a complete business platform — a professional website with live freight booking, M-Pesa STK Push payment collection, automated client receipts, and a follow-up sequence that sent a WhatsApp reminder to every unclosed enquiry within 24 hours.',
   result:'KES 840K in payments automated in the first 90 days. Lead follow-up time dropped from 4 hours per day to zero. Enquiry closure rate rose from 68% to 94%.',
   cost:'KES 180,000',costNote:'One-time build + 3-month maintenance',
   timeline:[{w:'Weeks 1–2',t:'Discovery & Architecture',d:'Stakeholder interviews, competitor audit, system design.'},{w:'Weeks 3–4',t:'Design & Content',d:'Brand language, UI design, copy — all approved before build.'},{w:'Weeks 5–6',t:'Core Platform Build',d:'Website, booking system, database setup.'},{w:'Weeks 7–8',t:'M-Pesa & Launch',d:'Daraja API, STK push testing, sandbox to production.'}],
   stack:['Astro 5','FastAPI','Daraja API','Supabase','Cloudflare Workers','Resend'],
   deliverables:['Professional website','M-Pesa STK Push payments','Automated email receipts','Lead follow-up automation','Admin dashboard','3-month maintenance'],
   imgs:[{l:'Homepage hero',c:['#0D2914','#1A3D22','#C9A84C']},{l:'Booking flow',c:['#112818','#2D6B3F','#4FFFB0']},{l:'Payment screen',c:['#0A1A0E','#C9A84C','#225230']},{l:'Admin dashboard',c:['#091410','#1A3D22','#4FFFB0']}],
   quote:'"Before AXIS we were losing money every month through disorganisation. Now the system runs itself. Three bookings taken overnight, two already paid."',
   client:'James Mutua',role:'CEO, Tuma Logistics',rating:5.0,url:'https://tumalogistics.co.ke'},
  {id:'msa',cat:'Legal',year:'2024',title:'MSA Legal Partners',
   tagline:'How a top-tier Mombasa law firm tripled their qualified client enquiries by rebuilding their digital presence from scratch.',
   problem:'MSA Legal Partners had a website built in 2018 with no mobile optimisation, no booking system, and a generic contact form generating mostly low-quality enquiries. Partners were spending hours in discovery calls with prospects who were not a good fit.',
   solution:'We rebuilt the entire presence around a qualification-first approach. The new site guides visitors through a short intake before they can book, automatically routing qualified leads to Calendly while sending others to a resource library. We also built a content system publishing two legal insights per month.',
   result:'3.1× increase in qualified client enquiries within 60 days. Partners report new enquiries arrive already knowing their fees — saving an average of 40 minutes per prospect.',
   cost:'KES 145,000',costNote:'One-time build + quarterly SEO reviews',
   timeline:[{w:'Weeks 1–2',t:'Brand & Positioning',d:'Repositioned from generic firm to specialist practice.'},{w:'Weeks 3–4',t:'Design System',d:'Typography, colour, UI — approved across all partners.'},{w:'Weeks 5–6',t:'Build & Launch',d:'Website, Calendly integration, email automation.'}],
   stack:['Next.js 14','Resend','Supabase','Calendly API','Vercel'],
   deliverables:['Professional multi-page website','Intake qualification flow','Calendly booking','Email automation','Monthly content system','Quarterly SEO review'],
   imgs:[{l:'Homepage',c:['#0C1C12','#1A3D22','#C9A84C']},{l:'Practice areas',c:['#0A1A0E','#225230','#C9A84C']},{l:'Intake flow',c:['#091410','#2D6B3F','#4FFFB0']},{l:'Mobile view',c:['#0C1C12','#1A3D22','#C9A84C']}],
   quote:'"The quality of our client pipeline has transformed completely. Every call is now with someone who knows what they need and can afford it."',
   client:'Senior Partner',role:'MSA Legal Partners',rating:5.0,url:'https://msalegalpartners.co.ke'},
  {id:'nyumba',cat:'Real Estate',year:'2023',title:'Nyumba Properties',
   tagline:'How Nyumba Properties escaped the aggregator trap and collected KES 2.1M in M-Pesa deposits in their first quarter.',
   problem:'Nyumba had been listing exclusively on a competitor aggregator, paying 8% commission on every rental, with no access to their own enquiry data and zero visibility under their own name.',
   solution:'We built an owned platform with property listings, interactive GeoJSON map integration, M-Pesa deposit collection directly on the listing page, automated WhatsApp notifications for both client and agent, and a simple CRM for agents.',
   result:'KES 2.1M in reservation deposits in first quarter. Zero aggregator commission paid. 340 properties live on the owned platform. 100% of client data now owned by Nyumba.',
   cost:'KES 220,000',costNote:'Full platform build + 6-month maintenance',
   timeline:[{w:'Weeks 1–2',t:'Platform Architecture',d:'Database schema, property model, map data, user flows.'},{w:'Weeks 3–5',t:'Core Platform',d:'Property listings, search, filter, map integration.'},{w:'Weeks 6–8',t:'M-Pesa & Communications',d:'Daraja deposit flow, WhatsApp integration.'},{w:'Weeks 9–10',t:'Migration & Launch',d:'340 properties migrated, agents trained, go-live.'}],
   stack:['Astro 5','Daraja API','Mapbox GL JS','Supabase','Twilio','Cloudflare'],
   deliverables:['Full property listing platform','Interactive map (Mombasa & Nairobi)','M-Pesa reservation deposits','WhatsApp agent notifications','Agent CRM','6-month maintenance'],
   imgs:[{l:'Property map',c:['#0A1A0E','#1A3D22','#4FFFB0']},{l:'Listing page',c:['#091410','#225230','#C9A84C']},{l:'M-Pesa deposit',c:['#0C1C12','#2D6B3F','#C9A84C']},{l:'Agent dashboard',c:['#0A1A0E','#1A3D22','#4FFFB0']}],
   quote:'"We were paying the aggregator KES 400K a year in commission. Now that money stays with us and our clients know our name, not theirs."',
   client:'Operations Director',role:'Nyumba Properties',rating:4.9,url:'https://nyumbaproperties.co.ke'},
  {id:'agri',cat:'Agritech',year:'2024',title:'Coast Agritech',
   tagline:'How Coast Agritech onboarded 1,240 farmers and disbursed KES 4.8M — fully automated — in 12 weeks.',
   problem:'Coast Agritech was managing 800+ farmer relationships through Excel and WhatsApp. Disbursements were manual M-Pesa transfers done one by one. Investor reporting required 3 days of manual compilation every month.',
   solution:'We built a farmer-data platform with mobile-first onboarding (works on 2G), automated M-Pesa B2C bulk disbursement paying multiple farmers simultaneously, yield tracking dashboards, and automated investor-ready monthly reports.',
   result:'1,240 farmers onboarded. KES 4.8M disbursed via automated bulk payments. Monthly reporting dropped from 3 days to 20 minutes. Founders featured in 3 national publications within 6 months.',
   cost:'KES 290,000',costNote:'Full platform + content system + 12-month maintenance',
   timeline:[{w:'Weeks 1–3',t:'Farmer Journey Design',d:'Mobile-first onboarding optimised for 2G smartphones.'},{w:'Weeks 4–6',t:'Core Platform',d:'Farmer profiles, yield tracking, dashboard.'},{w:'Weeks 7–9',t:'M-Pesa B2C',d:'Bulk disbursement, approval flow, audit trail.'},{w:'Weeks 10–11',t:'Reporting & Content',d:'Investor dashboard, auto-reports, content system.'},{w:'Week 12',t:'Launch & Training',d:'Staff training, data migration, go-live.'}],
   stack:['React','FastAPI','M-Pesa B2C API','PostgreSQL','CRON Workers','Resend'],
   deliverables:['Farmer onboarding (2G-ready)','Bulk M-Pesa disbursement','Yield & impact tracking','Investor reporting dashboard','Automated monthly reports','Authority content system','12-month maintenance'],
   imgs:[{l:'Farmer onboarding',c:['#0A1A0E','#225230','#4FFFB0']},{l:'Disbursement dashboard',c:['#091410','#1A3D22','#C9A84C']},{l:'Impact reporting',c:['#0C1C12','#2D6B3F','#4FFFB0']},{l:'Mobile farmer view',c:['#0A1A0E','#1A3D22','#C9A84C']}],
   quote:'"What used to take 3 days every month now runs automatically. The farmers trust the system — they can see their data and know exactly when disbursement is coming."',
   client:'Co-Founder',role:'Coast Agritech',rating:5.0,url:'https://coastagritech.co.ke'},
];

function stars(r){
  var h='';
  for(var i=0;i<5;i++) h+='<span style="font-size:13px;color:'+(i<Math.round(r)?'var(--gold)':'rgba(255,255,255,.2)')+'">★</span>';
  return h;
}

function drawMock(canvas,colors,title){
  if(!canvas)return;
  var cw=canvas.offsetWidth||400,ch=canvas.offsetHeight||225;
  canvas.width=cw*2;canvas.height=ch*2;
  var ctx=canvas.getContext('2d');ctx.scale(2,2);
  var bg=colors[0],ac1=colors[1],ac2=colors[2],PHI=1.618;
  ctx.fillStyle=bg;ctx.fillRect(0,0,cw,ch);
  ctx.fillStyle=ac1;ctx.fillRect(0,0,cw,22);
  ctx.fillStyle=ac2;ctx.fillRect(8,6,28,10);
  ctx.fillStyle='rgba(255,255,255,.6)';ctx.font='bold 6px monospace';ctx.fillText('AXIS',10,13);
  [cw-50,cw-34,cw-18].forEach(function(x){ctx.fillStyle='rgba(255,255,255,.3)';ctx.fillRect(x,8,16,5);});
  ctx.fillStyle=ac1;ctx.fillRect(0,22,cw,ch*.35);
  ctx.strokeStyle=ac2;ctx.globalAlpha=.18;ctx.lineWidth=.6;
  ctx.beginPath();var scx=cw*.72,scy=22+ch*.17;
  for(var a=0;a<Math.PI*4;a+=.1){var r=1.5*Math.pow(PHI,a/Math.PI/2);var px=scx+r*Math.cos(a);var py=scy+r*Math.sin(a);a===0?ctx.moveTo(px,py):ctx.lineTo(px,py);if(r>60)break;}
  ctx.stroke();ctx.globalAlpha=1;
  ctx.fillStyle=ac2;ctx.fillRect(14,30,cw*.42,8);
  ctx.fillStyle='rgba(255,255,255,.25)';ctx.fillRect(14,42,cw*.32,5);ctx.fillRect(14,50,cw*.25,5);
  ctx.fillStyle=ac2;ctx.beginPath();ctx.roundRect?ctx.roundRect(14,60,55,14,3):ctx.rect(14,60,55,14);ctx.fill();
  ctx.fillStyle=bg;ctx.font='bold 5px sans-serif';ctx.fillText('Get Started',17,69);
  var crd=(cw-40)/3;
  for(var i=0;i<3;i++){
    ctx.fillStyle=ac1;ctx.beginPath();ctx.roundRect?ctx.roundRect(10+i*(crd+5),22+ch*.35+8,crd,ch*.28,5):ctx.rect(10+i*(crd+5),22+ch*.35+8,crd,ch*.28);ctx.fill();
    ctx.fillStyle=ac2;ctx.fillRect(16+i*(crd+5),22+ch*.35+16,18,3);
    ctx.fillStyle='rgba(255,255,255,.18)';ctx.fillRect(16+i*(crd+5),22+ch*.35+22,crd-12,2);
  }
  ctx.fillStyle=ac1;ctx.fillRect(0,ch-14,cw,14);
}

function renderCards(){
  var wrap=document.getElementById('cards-wrap');
  wrap.innerHTML=PROJECTS.map(function(p){return '<div class="gc rv" id="pc-'+p.id+'" onclick="openProject(\''+p.id+'\')" style="border-radius:var(--r);overflow:hidden;cursor:pointer;margin-bottom:14px;"><div id="pi-'+p.id+'" style="display:grid;grid-template-columns:1fr clamp(170px,22vw,250px);gap:0;"><div style="padding:clamp(18px,3.5vw,28px);"><div style="display:flex;align-items:center;gap:8px;margin-bottom:12px;flex-wrap:wrap;"><span class="cat-tag">'+p.cat+'</span><span style="font-family:var(--fm);font-size:.5rem;color:var(--t3);">'+p.year+'</span><div style="display:flex;align-items:center;gap:5px;margin-left:auto;"><div class="dot"></div><span style="font-family:var(--fm);font-size:.52rem;color:rgba(79,255,176,.65);">Live</span></div></div><div style="font-family:var(--fd);font-size:clamp(1.3rem,2.2vw,1.7rem);font-weight:300;color:var(--t1);margin-bottom:7px;">'+p.title+'</div><p style="font-size:clamp(.78rem,1vw,.86rem);font-weight:300;color:var(--t2);line-height:1.64;margin-bottom:12px;">'+p.tagline+'</p><div class="rb" style="margin-bottom:10px;"><div class="rl">Result</div><div class="rval">'+p.result.split('.')[0]+'.</div></div><div style="display:flex;align-items:center;gap:8px;">'+stars(p.rating)+'<span style="font-family:var(--fd);font-size:1rem;font-weight:300;color:var(--gold);">'+p.rating+'</span><span style="font-family:var(--fm);font-size:.5rem;color:var(--t3);">/ 5.0</span></div></div><div style="padding:clamp(14px,2.5vw,22px);background:rgba(255,255,255,.02);border-left:1px solid rgba(255,255,255,.05);display:flex;flex-direction:column;justify-content:space-between;gap:14px;"><canvas id="ct-'+p.id+'" style="width:100%;border-radius:8px;border:1px solid var(--gb);display:block;aspect-ratio:16/9;"></canvas><div><div class="lbl" style="font-size:.5rem;margin-bottom:5px;">Project Cost</div><div style="font-family:var(--fd);font-size:clamp(1.1rem,1.8vw,1.3rem);font-weight:300;color:var(--gold);">'+p.cost+'</div><div style="font-family:var(--fm);font-size:.52rem;color:var(--t3);margin-top:2px;">'+p.costNote+'</div></div><div style="display:flex;align-items:center;justify-content:center;gap:8px;padding:9px;background:var(--gd2);border:1px solid var(--gbh);border-radius:8px;font-family:var(--fm);font-size:.58rem;letter-spacing:.08em;color:var(--gold);">View Full Case Study →</div></div></div></div>';}).join('');
  setTimeout(function(){
    PROJECTS.forEach(function(p){
      var c=document.getElementById('ct-'+p.id);
      if(c)drawMock(c,p.imgs[0].c,p.title);
    });
    var io=new IntersectionObserver(function(entries){entries.forEach(function(e){if(e.isIntersecting){e.target.classList.add('vis');io.unobserve(e.target);}});},{threshold:.06});
    document.querySelectorAll('.rv:not(.vis)').forEach(function(el){io.observe(el);});
  },60);
}
renderCards();

function rcl(){
  PROJECTS.forEach(function(p){
    var g=document.getElementById('pi-'+p.id);
    if(g)g.style.gridTemplateColumns=window.innerWidth<600?'1fr':'1fr clamp(170px,22vw,250px)';
  });
}
window.addEventListener('resize',rcl,{passive:true});

function openProject(id){
  var p=null;for(var i=0;i<PROJECTS.length;i++){if(PROJECTS[i].id===id){p=PROJECTS[i];break;}}
  if(!p)return;
  document.getElementById('d-meta').innerHTML='<span class="cat-tag">'+p.cat+'</span><span style="font-family:var(--fm);font-size:.5rem;color:var(--t3);">'+p.year+'</span><div style="display:flex;align-items:center;gap:5px;"><div class="dot"></div><span style="font-family:var(--fm);font-size:.52rem;color:rgba(79,255,176,.65);">Live</span></div>';
  document.getElementById('d-title').textContent=p.title;
  document.getElementById('d-tagline').textContent=p.tagline;

  var tl=p.timeline.map(function(t){return '<div class="tl-item"><div class="tl-dot">✓</div><div><div style="font-family:var(--fm);font-size:.52rem;color:var(--t3);text-transform:uppercase;letter-spacing:.07em;margin-bottom:2px;">'+t.w+'</div><div style="font-size:.9rem;font-weight:500;color:var(--t1);margin-bottom:2px;">'+t.t+'</div><div style="font-size:.78rem;font-weight:300;color:var(--t3);line-height:1.55;">'+t.d+'</div></div></div>';}).join('');
  var del=p.deliverables.map(function(d){return '<span class="chip chip-g">'+d+'</span>';}).join('');
  var stk=p.stack.map(function(s){return '<span class="chip">'+s+'</span>';}).join('');
  var gal=p.imgs.map(function(img,i){return '<div class="gimg rv" onclick="openModal(\''+id+'\','+i+')" style="transition-delay:'+(i*.07)+'s;"><canvas id="gi-'+id+'-'+i+'"></canvas><div class="gimg-label">'+img.l+'</div></div>';}).join('');

  document.getElementById('d-main').innerHTML=
    '<div class="rv" style="margin-bottom:clamp(24px,4vw,36px);"><div class="dsh">The Problem</div><p style="font-size:clamp(.82rem,1.1vw,.9rem);font-weight:300;color:var(--t2);line-height:1.74;">'+p.problem+'</p></div>'+
    '<div class="rv" style="margin-bottom:clamp(24px,4vw,36px);"><div class="dsh">Our Solution</div><p style="font-size:clamp(.82rem,1.1vw,.9rem);font-weight:300;color:var(--t2);line-height:1.74;">'+p.solution+'</p></div>'+
    '<div class="rv" style="margin-bottom:clamp(24px,4vw,36px);"><div class="dsh">The Result</div><div class="gc-dark" style="padding:clamp(16px,2.5vw,20px);"><p style="font-size:clamp(.82rem,1.1vw,.9rem);font-weight:300;color:var(--t1);line-height:1.74;">'+p.result+'</p></div></div>'+
    '<div class="rv" style="margin-bottom:clamp(24px,4vw,36px);"><div class="dsh">Project Timeline</div><div style="display:flex;flex-direction:column;gap:0;">'+tl+'</div></div>'+
    '<div class="rv" style="margin-bottom:clamp(24px,4vw,36px);"><div class="dsh">Deliverables</div><div class="chips">'+del+'</div></div>'+
    '<div class="rv" style="margin-bottom:clamp(24px,4vw,36px);"><div class="dsh">Technical Stack</div><div class="chips">'+stk+'</div></div>'+
    '<div class="rv" style="margin-bottom:clamp(24px,4vw,36px);"><div class="dsh">Portfolio Screenshots</div><div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(min(180px,100%),1fr));gap:10px;margin-top:10px;">'+gal+'</div></div>'+
    '<div class="rv"><div class="dsh">Client Feedback</div><div class="testimonial"><p style="font-size:clamp(.82rem,1.1vw,.9rem);font-weight:300;color:var(--t2);line-height:1.72;margin-bottom:14px;position:relative;z-index:1;">'+p.quote+'</p><div style="font-family:var(--fm);font-size:.58rem;color:var(--gold);">'+p.client+'</div><div style="font-family:var(--fm);font-size:.52rem;color:var(--t3);margin-top:2px;">'+p.role+'</div></div></div>';

  document.getElementById('d-sidebar').innerHTML=
    '<button onclick="window.open(\''+p.url+'\',\'_blank\')" style="display:flex;align-items:center;justify-content:center;gap:10px;width:100%;padding:13px;background:var(--gold);color:var(--gd);font-family:var(--fb);font-weight:600;font-size:.8rem;border:none;border-radius:10px;cursor:pointer;box-shadow:0 0 18px var(--gg);margin-bottom:10px;transition:all .18s;" onmouseover="this.style.boxShadow=\'0 0 30px rgba(201,168,76,.42)\'" onmouseout="this.style.boxShadow=\'0 0 18px var(--gg)\'">View Live Site ↗</button>'+
    '<div style="background:var(--gl2);border:1px solid var(--gb);border-radius:10px;padding:clamp(14px,2.5vw,20px);margin-bottom:10px;"><div class="lbl" style="font-size:.52rem;margin-bottom:8px;">Project Cost</div><div style="font-family:var(--fd);font-size:clamp(1.5rem,3vw,2rem);font-weight:300;color:var(--gold);">'+p.cost+'</div><div style="font-family:var(--fm);font-size:.52rem;color:var(--t3);margin-top:3px;">'+p.costNote+'</div></div>'+
    '<div style="background:var(--gl2);border:1px solid var(--gb);border-radius:10px;padding:clamp(14px,2.5vw,18px);text-align:center;margin-bottom:10px;"><div class="lbl" style="font-size:.52rem;margin-bottom:8px;">Client Rating</div><div style="font-family:var(--fd);font-size:2.6rem;font-weight:300;color:var(--gold);line-height:1;">'+p.rating+'</div><div style="display:flex;justify-content:center;gap:3px;margin:6px 0;">'+stars(p.rating).replace(/font-size:13px/g,'font-size:16px')+'</div><div class="lbl" style="font-size:.5rem;">Out of 5.0</div></div>'+
    '<div style="background:var(--gl2);border:1px solid var(--gb);border-radius:10px;padding:clamp(14px,2.5vw,18px);margin-bottom:10px;"><div class="lbl" style="font-size:.52rem;margin-bottom:10px;">Quick Facts</div><div style="font-family:var(--fm);font-size:.5rem;color:var(--t3);text-transform:uppercase;margin-bottom:2px;">Duration</div><div style="font-size:.86rem;color:var(--t2);margin-bottom:8px;">'+p.timeline.length*2+' weeks</div><div style="font-family:var(--fm);font-size:.5rem;color:var(--t3);text-transform:uppercase;margin-bottom:2px;">Industry</div><div style="font-size:.86rem;color:var(--t2);margin-bottom:8px;">'+p.cat+'</div><div style="font-family:var(--fm);font-size:.5rem;color:var(--t3);text-transform:uppercase;margin-bottom:2px;">Year</div><div style="font-size:.86rem;color:var(--t2);">'+p.year+'</div></div>'+
    '<div style="background:var(--gd2);border:1px solid var(--gbh);border-radius:10px;padding:clamp(14px,2.5vw,18px);"><div class="lbl" style="font-size:.52rem;margin-bottom:8px;">Want Similar Results?</div><p style="font-size:.8rem;font-weight:300;color:var(--t2);line-height:1.65;margin-bottom:12px;">Get a free assessment and see what we\'d recommend for your business.</p><a href="/assessment" class="btn-g" style="width:100%;justify-content:center;font-size:.7rem;">Start Free Assessment →</a></div>';

  document.getElementById('pg-list').style.display='none';
  document.getElementById('pg-detail').style.display='block';
  window.scrollTo({top:0,behavior:'smooth'});
  document.getElementById('detail-grid').style.gridTemplateColumns=window.innerWidth<700?'1fr':'1fr clamp(200px,25vw,300px)';

  setTimeout(function(){
    p.imgs.forEach(function(img,i){
      var c=document.getElementById('gi-'+id+'-'+i);
      if(c)drawMock(c,img.c,p.title);
    });
    var io2=new IntersectionObserver(function(entries){entries.forEach(function(e){if(e.isIntersecting){e.target.classList.add('vis');io2.unobserve(e.target);}});},{threshold:.06});
    document.querySelectorAll('#pg-detail .rv:not(.vis)').forEach(function(el){io2.observe(el);});
  },80);
}

function goList(){
  document.getElementById('pg-detail').style.display='none';
  document.getElementById('pg-list').style.display='block';
  window.scrollTo({top:0,behavior:'smooth'});
}

function openModal(pid,idx){
  var p=null;for(var i=0;i<PROJECTS.length;i++){if(PROJECTS[i].id===pid){p=PROJECTS[i];break;}}
  if(!p)return;
  document.getElementById('img-modal').style.display='flex';
  var mc=document.getElementById('modal-c');
  drawMock(mc,p.imgs[idx].c,p.title);
  document.getElementById('modal-lbl').textContent=p.imgs[idx].l+' — '+p.title;
}
function closeModal(){document.getElementById('img-modal').style.display='none';}

window.addEventListener('resize',function(){
  var dg=document.getElementById('detail-grid');
  if(dg&&document.getElementById('pg-detail').style.display!=='none')
    dg.style.gridTemplateColumns=window.innerWidth<700?'1fr':'1fr clamp(200px,25vw,300px)';
  var tg=document.getElementById('trust-g');
  if(tg)tg.style.gridTemplateColumns=window.innerWidth<480?'1fr 1fr':'repeat(4,1fr)';
  rcl();
},{passive:true});

var tg=document.getElementById('trust-g');
if(tg)tg.style.gridTemplateColumns=window.innerWidth<480?'1fr 1fr':'repeat(4,1fr)';
</script>
